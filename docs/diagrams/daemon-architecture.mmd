---
title: MG Daemon Architecture
---
graph TB
    subgraph USER_PROVIDES["User Provides"]
        style USER_PROVIDES fill:#fff3cd,stroke:#ffc107,stroke-width:2px
        CONFIG[".mg-daemon.json<br/><i>Provider credentials,<br/>polling interval, batch size</i>"]
        TICKETS["Tickets<br/><i>Labeled with mg-daemon</i>"]
    end

    subgraph PREREQUISITES["Prerequisites (install once)"]
        style PREREQUISITES fill:#d4edda,stroke:#28a745,stroke-width:2px
        NODE["Node.js<br/><i>volta install node</i>"]
        GH["GitHub CLI<br/><i>brew install gh</i>"]
        CLAUDE["Claude Code CLI<br/><i>claude.ai/claude-code</i>"]
        GIT["Git"]
    end

    subgraph MAC_MINI["Mac Mini (24/7)"]
        style MAC_MINI fill:#e8f4fd,stroke:#0d6efd,stroke-width:3px

        subgraph LAUNCHD["launchd Service"]
            style LAUNCHD fill:#f8f9fa,stroke:#6c757d
            PLIST["com.mg-daemon.plist<br/><i>KeepAlive, ThrottleInterval:30s<br/>ProcessType: Background</i>"]
        end

        subgraph DAEMON["mg-daemon process"]
            style DAEMON fill:#fff,stroke:#0d6efd,stroke-width:2px

            subgraph POLL_LOOP["Poll Loop (every 5min)"]
                style POLL_LOOP fill:#f0f7ff,stroke:#0d6efd
                STOP_CHECK{"STOP<br/>sentinel?"}
                DISK_CHECK{"Disk<br/>>5GB?"}
                ERROR_CHECK{"Error<br/>budget<br/>OK?"}
                POLL["Poll Provider"]
                DEDUP["Filter<br/>processed"]
            end

            subgraph PIPELINE["Per-Ticket Pipeline"]
                style PIPELINE fill:#f0fff0,stroke:#28a745
                TRIAGE["Triage<br/><i>GO / NEEDS_INFO / REJECT</i>"]
                PLAN["Plan<br/><i>claude --print</i>"]
                WORKTREE["Create<br/>Worktree"]
                EXECUTE["Execute<br/>Workstreams<br/><i>claude --print<br/>--permission-mode<br/>bypassPermissions</i>"]
                MERGE_MAIN["Merge<br/>main"]
                QUALITY["Quality Gates<br/><i>vitest run + tsc</i>"]
                COMMIT["git add/commit/push"]
                CREATE_PR["Create<br/>Draft PR"]
                WRITEBACK["Write-back<br/><i>subtasks, status,<br/>comments, PR link</i>"]
            end

            subgraph SAFETY["Safety Layer"]
                style SAFETY fill:#fff0f0,stroke:#dc3545
                CONCURRENCY["Concurrency<br/>Limiter<br/><i>default: 1</i>"]
                TIMEOUT["Claude<br/>Timeout<br/><i>30 min</i>"]
                OUTPUT_CAP["Output Cap<br/><i>50 MB</i>"]
                ENV_SCRUB["Env<br/>Scrub<br/><i>strips tokens</i>"]
                PROC_GROUP["Process<br/>Group Kill"]
                HEARTBEAT["Heartbeat"]
                LOG_ROTATE["Log<br/>Rotation<br/><i>10MB x 5</i>"]
                ERR_BUDGET["Error<br/>Budget<br/><i>pause after 3</i>"]
            end
        end

        subgraph STATE[".mg-daemon/ State Files"]
            style STATE fill:#f8f9fa,stroke:#6c757d
            PID["daemon.pid"]
            PROCESSED["processed.json"]
            HB_FILE["heartbeat"]
            EB_FILE["error-budget.json"]
            LOGS["daemon.log"]
            WORKTREES["worktrees/<br/><i>GH-16/, GH-15/</i>"]
        end
    end

    subgraph PROVIDERS["Ticket Providers"]
        style PROVIDERS fill:#f5f0ff,stroke:#6f42c1,stroke-width:2px
        GITHUB_ISSUES["GitHub Issues<br/><i>gh CLI</i>"]
        JIRA["Jira<br/><i>REST API v3</i>"]
        LINEAR["Linear<br/><i>GraphQL API</i>"]
    end

    subgraph GITHUB_REPO["GitHub Repository"]
        style GITHUB_REPO fill:#f5f0ff,stroke:#6f42c1,stroke-width:2px
        BRANCHES["Feature<br/>Branches"]
        DRAFT_PRS["Draft PRs"]
        GH_ACTIONS["GitHub Actions<br/><i>auto-update-branches.yml<br/>ci.yml</i>"]
    end

    HUMAN["Developer<br/><i>Reviews & merges PRs</i>"]

    %% Connections
    CONFIG --> DAEMON
    TICKETS --> PROVIDERS
    NODE & GH & CLAUDE & GIT --> DAEMON

    PLIST --> DAEMON

    STOP_CHECK -->|No| DISK_CHECK
    STOP_CHECK -->|"Yes (HALT)"| STOP_CHECK
    DISK_CHECK -->|OK| ERROR_CHECK
    ERROR_CHECK -->|OK| POLL
    POLL --> DEDUP

    DEDUP --> TRIAGE
    TRIAGE -->|GO| PLAN
    PLAN --> WORKTREE
    WORKTREE --> EXECUTE
    EXECUTE --> MERGE_MAIN
    MERGE_MAIN --> QUALITY
    QUALITY --> COMMIT
    COMMIT --> CREATE_PR
    CREATE_PR --> WRITEBACK

    POLL --> PROVIDERS
    WRITEBACK --> PROVIDERS
    COMMIT --> BRANCHES
    CREATE_PR --> DRAFT_PRS

    CONCURRENCY -.-> EXECUTE
    TIMEOUT -.-> EXECUTE
    OUTPUT_CAP -.-> EXECUTE
    ENV_SCRUB -.-> EXECUTE
    PROC_GROUP -.-> EXECUTE
    ERR_BUDGET -.-> ERROR_CHECK

    DAEMON --> STATE
    GH_ACTIONS --> BRANCHES
    DRAFT_PRS --> HUMAN
