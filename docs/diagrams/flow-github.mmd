---
title: "GitHub Issues Flow"
---
flowchart TD
    START(["Daemon Poll Cycle"])

    subgraph POLL["1. Poll"]
        GH_LIST["gh issue list<br/>--repo owner/repo<br/>--json number,title,body,labels,url<br/>--search 'label:mg-daemon state:open'"]
        NORMALIZE["Normalize to NormalizedTicket<br/><i>id: GH-{number}<br/>source: github<br/>priority: from labels</i>"]
    end

    subgraph FILTER["2. Filter"]
        CHECK_PROCESSED{"In<br/>processed.json?"}
        SKIP["Skip<br/><i>already handled</i>"]
    end

    subgraph TRIAGE_PHASE["3. Triage"]
        TRIAGE_CLAUDE["claude --print<br/><i>Evaluate: scope, clarity,<br/>feasibility, size, safety</i>"]
        TRIAGE_RESULT{"Verdict?"}
        TRIAGE_GO["GO"]
        TRIAGE_NEEDS["NEEDS_CLARIFICATION"]
        TRIAGE_REJECT["REJECT"]
        GH_COMMENT_NEEDS["gh issue comment {n}<br/>--body 'Please clarify...'"]
        GH_LABEL_NEEDS["gh issue edit {n}<br/>--add-label mg-daemon:needs-info"]
        GH_COMMENT_REJECT["gh issue comment {n}<br/>--body 'Rejected because...'"]
        GH_LABEL_REJECT["gh issue edit {n}<br/>--add-label mg-daemon:rejected"]
    end

    subgraph PLAN_PHASE["4. Plan"]
        PLAN_CLAUDE["claude --print<br/><i>Break into workstreams<br/>WS: name / AC: criteria</i>"]
        SUBTASKS["gh issue create<br/><i>per workstream<br/>body: 'Parent: #{n}'</i>"]
    end

    subgraph EXECUTE_PHASE["5. Execute"]
        WORKTREE["git worktree add<br/>.mg-daemon/worktrees/GH-{n}"]
        EXEC_LOOP["For each workstream:<br/>claude --print<br/>--permission-mode bypassPermissions<br/><i>cwd: worktree path</i>"]
        STATUS_PROGRESS["gh issue edit {n}<br/>--add-label status:in_progress<br/>--remove-label status:todo"]
    end

    subgraph QUALITY["6. Quality Gates"]
        MERGE_MAIN["git fetch origin main<br/>git merge origin/main"]
        GIT_ADD["git add -A"]
        RUN_TESTS["npx vitest run"]
        RUN_BUILD["npx tsc"]
        TEST_RESULT{"Tests<br/>pass?"}
        ANNOTATE["Add test results<br/>to PR body"]
    end

    subgraph DELIVER["7. Deliver"]
        GIT_COMMIT["git commit -m<br/>'feat(GH-{n}): title'"]
        GIT_PUSH["git push -u origin<br/>feature/GH-{n}-slug"]
        GH_PR["gh pr create --draft<br/>--head feature/GH-{n}-slug<br/>--base main<br/>--title '[GH-{n}] title'<br/>--body '...'"]
        STATUS_REVIEW["gh issue edit {n}<br/>--add-label status:in_review"]
        CLEANUP["git worktree remove<br/>.mg-daemon/worktrees/GH-{n}"]
    end

    HUMAN_REVIEW(["Developer Reviews PR"])

    %% Flow
    START --> GH_LIST --> NORMALIZE --> CHECK_PROCESSED
    CHECK_PROCESSED -->|Yes| SKIP
    CHECK_PROCESSED -->|No| TRIAGE_CLAUDE

    TRIAGE_CLAUDE --> TRIAGE_RESULT
    TRIAGE_RESULT --> TRIAGE_GO
    TRIAGE_RESULT --> TRIAGE_NEEDS
    TRIAGE_RESULT --> TRIAGE_REJECT
    TRIAGE_NEEDS --> GH_COMMENT_NEEDS --> GH_LABEL_NEEDS --> SKIP
    TRIAGE_REJECT --> GH_COMMENT_REJECT --> GH_LABEL_REJECT --> SKIP

    TRIAGE_GO --> PLAN_CLAUDE
    PLAN_CLAUDE --> SUBTASKS --> STATUS_PROGRESS

    STATUS_PROGRESS --> WORKTREE --> EXEC_LOOP

    EXEC_LOOP --> MERGE_MAIN --> GIT_ADD --> RUN_TESTS --> RUN_BUILD
    RUN_BUILD --> TEST_RESULT
    TEST_RESULT -->|Pass| GIT_COMMIT
    TEST_RESULT -->|Fail| ANNOTATE --> GIT_COMMIT

    GIT_COMMIT --> GIT_PUSH --> GH_PR --> STATUS_REVIEW --> CLEANUP --> HUMAN_REVIEW

    %% Styling
    style START fill:#0d6efd,color:#fff
    style HUMAN_REVIEW fill:#28a745,color:#fff
    style SKIP fill:#ffc107,color:#000
    style TRIAGE_GO fill:#28a745,color:#fff
    style TRIAGE_NEEDS fill:#ffc107,color:#000
    style TRIAGE_REJECT fill:#dc3545,color:#fff
