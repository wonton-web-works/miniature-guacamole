---
title: "Linear Flow"
---
flowchart TD
    START(["Daemon Poll Cycle"])

    subgraph POLL["1. Poll"]
        LINEAR_GQL["POST https://api.linear.app/graphql<br/><i>query { issues(filter: ...) }<br/>Auth: Bearer apiKey</i>"]
        NORMALIZE["Normalize to NormalizedTicket<br/><i>id: LIN-{identifier}<br/>source: linear<br/>priority: 1→critical,<br/>2→high, 3→medium,<br/>4→low, 0→medium</i>"]
    end

    subgraph FILTER["2. Filter"]
        CHECK_PROCESSED{"In<br/>processed.json?"}
        SKIP["Skip"]
    end

    subgraph TRIAGE_PHASE["3. Triage"]
        TRIAGE_CLAUDE["claude --print<br/><i>Evaluate ticket</i>"]
        TRIAGE_RESULT{"Verdict?"}
        TRIAGE_GO["GO"]
        TRIAGE_NEEDS["NEEDS_CLARIFICATION"]
        LINEAR_COMMENT["mutation { commentCreate<br/>(input: { issueId, body }) }"]
    end

    subgraph PLAN_PHASE["4. Plan"]
        PLAN_CLAUDE["claude --print<br/><i>Break into workstreams</i>"]
        SUBTASKS["mutation { issueCreate<br/>(input: { title, description,<br/>teamId, parentId }) }<br/><i>per workstream</i>"]
        LOOKUP_STATES["query { team(id) {<br/>states { nodes { id name } } } }"]
        TRANSITION_PROGRESS["mutation { issueUpdate<br/>(id, input: { stateId }) }<br/><i>→ In Progress</i>"]
    end

    subgraph EXECUTE_PHASE["5. Execute"]
        WORKTREE["git worktree add"]
        EXEC_LOOP["For each workstream:<br/>claude --print<br/>--permission-mode bypassPermissions"]
    end

    subgraph QUALITY["6. Quality Gates"]
        MERGE_MAIN["Merge latest main"]
        TESTS["vitest run + tsc"]
    end

    subgraph DELIVER["7. Deliver"]
        GIT_PUSH["git commit + push"]
        GH_PR["gh pr create --draft"]
        LINEAR_ATTACH["mutation { attachmentCreate<br/>(input: { issueId,<br/>title: 'Draft PR',<br/>url: prUrl }) }"]
        TRANSITION_REVIEW["mutation { issueUpdate<br/>(id, input: { stateId }) }<br/><i>→ In Review</i>"]
        CLEANUP["Cleanup worktree"]
    end

    HUMAN(["Developer Reviews PR"])

    %% Flow
    START --> LINEAR_GQL --> NORMALIZE --> CHECK_PROCESSED
    CHECK_PROCESSED -->|Yes| SKIP
    CHECK_PROCESSED -->|No| TRIAGE_CLAUDE

    TRIAGE_CLAUDE --> TRIAGE_RESULT
    TRIAGE_RESULT --> TRIAGE_GO
    TRIAGE_RESULT --> TRIAGE_NEEDS
    TRIAGE_NEEDS --> LINEAR_COMMENT --> SKIP

    TRIAGE_GO --> PLAN_CLAUDE --> SUBTASKS --> LOOKUP_STATES --> TRANSITION_PROGRESS
    TRANSITION_PROGRESS --> WORKTREE --> EXEC_LOOP
    EXEC_LOOP --> MERGE_MAIN --> TESTS
    TESTS --> GIT_PUSH --> GH_PR --> LINEAR_ATTACH --> TRANSITION_REVIEW --> CLEANUP --> HUMAN

    style START fill:#5E6AD2,color:#fff
    style HUMAN fill:#28a745,color:#fff
    style SKIP fill:#ffc107,color:#000
    style TRIAGE_GO fill:#28a745,color:#fff
    style TRIAGE_NEEDS fill:#ffc107,color:#000
