  },
  "homepage": "https://rivermark-research.github.io/miniature-guacamole",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "puppeteer": "^24.36.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
