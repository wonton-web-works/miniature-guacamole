---
import Base from '../layouts/Base.astro';
import TerminalAnimation from '../components/TerminalAnimation.tsx';

const characters = [
  {
    key: 'em',
    role: 'Engineering Manager',
    abbr: 'EM',
    color: '#4A7C59',
    bio: 'Runs the process. Has seen things.',
  },
  {
    key: 'cto',
    role: 'CTO',
    abbr: 'CTO',
    color: '#2E6E8E',
    bio: 'Raises one eyebrow at your architecture.',
  },
  {
    key: 'po',
    role: 'Product Owner',
    abbr: 'PO',
    color: '#8B4A2E',
    bio: 'Knows what the users actually want.',
  },
  {
    key: 'qa',
    role: 'QA Engineer',
    abbr: 'QA',
    color: '#7A5C8B',
    bio: 'Writes tests first. Has opinions.',
  },
  {
    key: 'se',
    role: 'Staff Engineer',
    abbr: 'SE',
    color: '#3D5A6B',
    bio: 'Knows where the bodies are buried.',
  },
  {
    key: 'ceo',
    role: 'CEO',
    abbr: 'CEO',
    color: '#2D2D2D',
    bio: 'Composed. Has the 30,000-foot view.',
  },
];

const commands = [
  { cmd: '/mg-build', desc: 'Classify, test, implement, review, ship — the full CAD cycle.' },
  { cmd: '/mg-assess', desc: 'Evaluate work quality before committing to a plan.' },
  { cmd: '/mg-leadership-team', desc: 'Convene EM, CTO, and PO to review a workstream.' },
];

const workflow = [
  { step: '01', label: 'Classify', detail: 'MECHANICAL, CREATIVE, or RESEARCH' },
  { step: '02', label: 'Test', detail: 'QA writes failing specs first' },
  { step: '03', label: 'Build', detail: 'DEV implements to pass' },
  { step: '04', label: 'Review', detail: 'SE and QA gate the output' },
  { step: '05', label: 'Ship', detail: 'EM signs off, memory written' },
];

const changelog = [
  {
    version: 'v4.2.0',
    date: '2026-03-20',
    title: 'Full Pipeline',
    notes: [
      'Post-PR code review — daemon invokes leadership review after every PR',
      'Merge automation — approved PRs merge automatically, rejections loop back to dev',
      'Lifecycle state sync — .claude/memory/ tracks every phase from planning to merged',
    ],
  },
  {
    version: 'v4.1.0',
    date: '2026-03-19',
    title: 'Output Parity',
    notes: [
      'Compact [ROLE] prefix output — every agent speaks in one line',
      'Timing instrumentation — per-step and total elapsed',
      'ANSI color codes matching brand palette per agent',
    ],
  },
  {
    version: 'v4.0.0',
    date: '2026-03-19',
    title: 'Framework Hardening',
    notes: [
      'Base template inheritance — 42% less boilerplate per agent',
      '2-track dev cycle — MECHANICAL (1 spawn) vs ARCHITECTURAL (5-6)',
      'Agent message bus for inter-agent communication',
    ],
  },
  {
    version: 'v3.1.0',
    date: '2026-03-19',
    title: 'State Reconciliation',
    notes: [
      '/mg-tidy skill for issue dedup + memory sync',
      'Daemon launchd auto-start with PATH fix',
      'Post-approval state sync in development cycle',
    ],
  },
];

const installCmd = 'curl -fsSL https://raw.githubusercontent.com/wonton-web-works/miniature-guacamole/main/install.sh | bash';
---

<Base>
  <main>
    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <h1 class="hero-headline">
              <span class="hero-headline-light">20 engineers.</span>
              <br />
              <span class="hero-headline-bold">Zero salaries.</span>
            </h1>

            <p class="hero-subtitle">
              PrivateEnterprise gives Claude Code a complete product development org — Engineering Manager, QA, Staff Engineer, and more. Every agent has a role. Memory is project-local. No hallway meetings.
            </p>

            <div class="hero-actions">
              <a
                href="https://github.com/wonton-web-works/miniature-guacamole"
                class="cta-primary"
              >
                Get Started
              </a>
            </div>

            <p class="hero-stats">
              <span class="mono">20 agents · 19 skills · 6 protocols</span>
            </p>
          </div>

          <div class="hero-terminal">
            <TerminalAnimation client:load />
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         WHAT IT DOES
    ============================================================ -->
    <section class="what-it-does">
      <div class="container">
        <p class="section-lead">
          One command spawns the right agents for the job. They coordinate, gate their own output, and hand off results in memory — without you managing the process.
        </p>

        <div class="commands-list">
          {commands.map(({ cmd, desc }) => (
            <div class="command-row">
              <span class="command-name mono">{cmd}</span>
              <span class="command-desc">{desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         MEET THE TEAM
    ============================================================ -->
    <section class="meet-the-team">
      <div class="container">
        <h2 class="section-heading">Meet the team</h2>
        <p class="section-sublead">20 agents, 4 levels — just like a real org.</p>

        <!-- Tier 1: Executive -->
        <div class="org-tier">
          <span class="tier-label mono">Executive</span>
          <div class="tier-row tier-1">
            <div class="agent-card" style="border-color: #8A9BB0;">
              <span class="agent-abbr mono" style="color: #8A9BB0;">CEO</span>
              <span class="agent-role">CEO</span>
              <p class="agent-bio">Composed. Has the 30,000-foot view.</p>
            </div>
          </div>
        </div>

        <div class="org-connector-line"></div>

        <!-- Tier 2: Leadership -->
        <div class="org-tier">
          <span class="tier-label mono">Leadership</span>
          <div class="tier-row tier-2">
            <div class="agent-card" style="border-color: #2E6E8E;">
              <span class="agent-abbr mono" style="color: #2E6E8E;">CTO</span>
              <span class="agent-role">CTO</span>
              <p class="agent-bio">Raises one eyebrow at your architecture.</p>
            </div>
            <div class="agent-card" style="border-color: #4A7C59;">
              <span class="agent-abbr mono" style="color: #4A7C59;">EM</span>
              <span class="agent-role">Engineering Manager</span>
              <p class="agent-bio">Runs the process. Has seen things.</p>
            </div>
            <div class="agent-card" style="border-color: #8B4A2E;">
              <span class="agent-abbr mono" style="color: #8B4A2E;">PO</span>
              <span class="agent-role">Product Owner</span>
              <p class="agent-bio">Knows what the users actually want.</p>
            </div>
          </div>
        </div>

        <div class="org-connector-line"></div>

        <!-- Tier 3: Senior ICs -->
        <div class="org-tier">
          <span class="tier-label mono">Senior ICs</span>
          <div class="tier-row tier-3">
            <div class="agent-card" style="border-color: #3D5A6B;">
              <span class="agent-abbr mono" style="color: #3D5A6B;">SE</span>
              <span class="agent-role">Staff Engineer</span>
              <p class="agent-bio">Knows where the bodies are buried.</p>
            </div>
            <div class="agent-card" style="border-color: #7A5C8B;">
              <span class="agent-abbr mono" style="color: #7A5C8B;">QA</span>
              <span class="agent-role">QA Engineer</span>
              <p class="agent-bio">Writes tests first. Has opinions.</p>
            </div>
          </div>
        </div>

        <div class="org-connector-line"></div>

        <!-- Tier 4: Specialists -->
        <div class="org-tier">
          <span class="tier-label mono">Specialists</span>
          <div class="tier-row tier-4">
            <div class="agent-card-sm">Dev</div>
            <div class="agent-card-sm">Designer</div>
            <div class="agent-card-sm">Security</div>
            <div class="agent-card-sm">DevOps</div>
            <div class="agent-card-sm">API Design</div>
            <div class="agent-card-sm">Data</div>
            <div class="agent-card-sm">Tech Writer</div>
            <div class="agent-card-sm">Copywriter</div>
          </div>
          <p class="tier-note mono">+ 12 more specialist agents</p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS
    ============================================================ -->
    <section class="how-it-works">
      <div class="container">
        <h2 class="section-heading">How it works</h2>
        <p class="section-sublabel mono">The CAD workflow — every build follows this sequence</p>

        <div class="workflow-timeline">
          {workflow.map(({ step, label, detail }, i) => (
            <div class="wf-item">
              <div class="wf-marker">
                <span class="wf-dot"></span>
                {i < workflow.length - 1 && <span class="wf-line"></span>}
              </div>
              <div class="wf-content">
                <span class="wf-step mono">{step}</span>
                <h3 class="wf-label">{label}</h3>
                <p class="wf-detail mono">{detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         INSTALL
    ============================================================ -->
    <section class="install">
      <div class="container">
        <h2 class="section-heading">Install</h2>
        <div class="install-block">
          <code class="install-cmd mono" id="install-cmd">{installCmd}</code>
          <button class="copy-btn mono" id="copy-btn" aria-label="Copy install command">
            copy
          </button>
        </div>
        <p class="install-note">Works anywhere Claude Code is installed. PrivateEnterprise is the commercial product built on the miniature-guacamole open-source framework.</p>
      </div>
    </section>

    <!-- ============================================================
         VALUE CTA
    ============================================================ -->
    <section class="value-cta">
      <div class="container">
        <h2 class="value-cta-headline">Replace a 5-person team.<br />Keep one engineer.</h2>
        <p class="value-cta-sub">
          PrivateEnterprise runs your full development lifecycle — triage, planning, code, review, merge — 24/7. Pricing reflects team replacement, not tooling.
        </p>
        <div class="value-cta-actions">
          <a href="/pilot" class="cta-primary">Start a Pilot</a>
          <a
            href="mailto:byazaki@wontonwebworks.com?subject=PrivateEnterprise"
            class="cta-secondary"
          >Book a Call</a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CHANGELOG
    ============================================================ -->
    <section class="changelog">
      <div class="container">
        <h2 class="section-heading">Changelog</h2>

        <div class="changelog-list">
          {changelog.map(({ version, date, title, notes }) => (
            <div class="changelog-entry">
              <div class="changelog-meta">
                <span class="changelog-version mono">{version}</span>
                <span class="changelog-date mono">{date}</span>
              </div>
              <div class="changelog-body">
                <h3 class="changelog-title">{title}</h3>
                <ul class="changelog-notes">
                  {notes.map((note) => (
                    <li>{note}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         FOOTER
    ============================================================ -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-links">
          <a
            href="https://github.com/wonton-web-works/miniature-guacamole"
            class="footer-link"
          >
            GitHub
          </a>
          <a
            href="https://github.com/wonton-web-works/miniature-guacamole/tree/main/docs"
            class="footer-link"
          >
            Docs
          </a>
        </div>
        <span class="footer-credit mono">Built by Wonton Web Works</span>
      </div>
    </footer>
  </main>

  <script>
    const btn = document.getElementById('copy-btn');
    const cmd = document.getElementById('install-cmd');

    if (btn && cmd) {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(cmd.textContent ?? '');
          const original = btn.textContent;
          btn.textContent = 'copied';
          btn.setAttribute('aria-label', 'Copied');
          setTimeout(() => {
            btn.textContent = original;
            btn.setAttribute('aria-label', 'Copy install command');
          }, 2000);
        } catch {
          // Clipboard not available — silently ignore
        }
      });
    }
  </script>
</Base>

<style>
  /* -------------------------------------------------------
     Shared utilities
  ------------------------------------------------------- */
  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 80px);
  }

  .mono {
    font-family: var(--font-mono);
  }

  /* -------------------------------------------------------
     HERO
  ------------------------------------------------------- */
  .hero {
    padding: clamp(80px, 12vw, 160px) 0 calc(clamp(60px, 8vw, 120px) + 40px);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), 0 100%);
    border-bottom: none;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-terminal {
      order: -1;
    }
    .hero-headline {
      font-size: clamp(40px, 10vw, 56px);
    }
    .hero-subtitle {
      max-width: 100%;
    }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(52px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }

  .hero-headline-light {
    font-weight: 400;
    color: var(--mg-text);
  }

  .hero-headline-bold {
    font-weight: 800;
    color: var(--mg-text);
  }

  .hero-subtitle {
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.65;
    color: var(--mg-subtext);
    max-width: 480px;
    margin-bottom: 36px;
  }

  .hero-actions {
    margin-bottom: 28px;
  }

  .cta-primary {
    display: inline-block;
    background: var(--mg-guac);
    color: #ffffff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    padding: 14px 28px;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.15s ease;
  }

  .cta-primary:hover {
    opacity: 0.88;
  }

  .hero-stats {
    font-size: 13px;
    color: var(--mg-subtext);
    letter-spacing: 0.04em;
  }

  .hero-stats .mono {
    color: var(--mg-cilantro);
  }

  /* Capybara characters — waiting for production art from WS-STUDIO-2 (#7) */

  /* -------------------------------------------------------
     WHAT IT DOES
  ------------------------------------------------------- */
  .what-it-does {
    padding: clamp(60px, 8vw, 120px) 0;
    clip-path: polygon(0 40px, 100% 0, 100% 100%, 0 100%);
    margin-top: -40px;
    border-bottom: 1px solid var(--mg-surface);
  }

  .section-lead {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.6;
    color: var(--mg-subtext);
    max-width: 640px;
    margin-bottom: 48px;
  }

  .commands-list {
    display: flex;
    flex-direction: column;
  }

  .command-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 18px 0;
    border-top: 1px solid var(--mg-surface);
  }

  .command-row:last-child {
    border-bottom: 1px solid var(--mg-surface);
  }

  .command-name {
    font-size: 14px;
    color: var(--mg-cilantro);
    letter-spacing: 0.02em;
  }

  .command-desc {
    font-size: 14px;
    color: var(--mg-subtext);
    line-height: 1.5;
  }

  @media (max-width: 560px) {
    .command-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  /* -------------------------------------------------------
     MEET THE TEAM
  ------------------------------------------------------- */
  .meet-the-team {
    padding: clamp(60px, 8vw, 120px) 0;
    border-bottom: 1px solid var(--mg-surface);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    color: var(--mg-text);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .section-sublead {
    font-size: 15px;
    color: var(--mg-subtext);
    margin-bottom: 48px;
  }

  /* Org tiers */
  .org-tier {
    position: relative;
  }

  .tier-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mg-subtext);
    margin-bottom: 16px;
    display: block;
  }

  .tier-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tier-1 {
    justify-content: flex-start;
  }

  .tier-2 {
    justify-content: flex-start;
  }

  .tier-3 {
    justify-content: flex-start;
  }

  .tier-4 {
    justify-content: flex-start;
    gap: 10px;
  }

  .org-connector-line {
    width: 2px;
    height: 28px;
    background: var(--mg-cilantro);
    opacity: 0.3;
    margin: 0 0 0 40px;
  }

  /* Agent cards — full bio cards for tiers 1-3 */
  .agent-card {
    background: var(--mg-surface);
    border: 1px solid #263040;
    border-top: 3px solid;
    border-radius: 6px;
    padding: 20px;
    min-width: 200px;
    max-width: 260px;
    flex: 1;
  }

  .agent-abbr {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 6px;
  }

  .agent-role {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--mg-text);
    display: block;
    line-height: 1.2;
  }

  .agent-bio {
    font-size: 13px;
    color: var(--mg-subtext);
    line-height: 1.5;
    margin-top: 8px;
  }

  /* Small agent pills for tier 4 */
  .agent-card-sm {
    background: var(--mg-surface);
    border: 1px solid #263040;
    border-radius: 4px;
    padding: 8px 16px;
    font-size: 13px;
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--mg-subtext);
  }

  .tier-note {
    font-size: 12px;
    color: #3A4A5C;
    margin-top: 12px;
  }

  @media (max-width: 560px) {
    .tier-row {
      flex-direction: column;
      gap: 12px;
    }
    .tier-4.tier-row {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
    }
    .agent-card {
      max-width: 100%;
    }
    .org-tier {
      margin-bottom: 4px;
    }
    .org-connector-line {
      margin-left: 24px;
      height: 20px;
    }
  }

  /* -------------------------------------------------------
     HOW IT WORKS — vertical timeline
  ------------------------------------------------------- */
  .how-it-works {
    padding: clamp(60px, 8vw, 120px) 0;
    border-bottom: 1px solid var(--mg-surface);
  }

  .section-sublabel {
    font-size: 12px;
    color: var(--mg-subtext);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 48px;
    margin-top: -28px;
  }

  .workflow-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 520px;
  }

  .wf-item {
    display: flex;
    gap: 24px;
  }

  .wf-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 6px;
  }

  .wf-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--mg-chili);
    flex-shrink: 0;
  }

  .wf-line {
    width: 2px;
    flex: 1;
    background: #263040;
    min-height: 20px;
  }

  .wf-content {
    padding-bottom: 32px;
  }

  .wf-item:last-child .wf-content {
    padding-bottom: 0;
  }

  .wf-step {
    font-size: 11px;
    color: var(--mg-chili);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 4px;
  }

  .wf-label {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--mg-text);
    margin-bottom: 4px;
  }

  .wf-detail {
    font-size: 12px;
    color: var(--mg-subtext);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  /* -------------------------------------------------------
     VALUE CTA
  ------------------------------------------------------- */
  .value-cta {
    padding: clamp(80px, 12vw, 160px) 0;
    border-bottom: 1px solid var(--mg-surface);
    text-align: center;
  }

  .value-cta-headline {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 800;
    color: var(--mg-text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .value-cta-sub {
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.65;
    color: var(--mg-subtext);
    max-width: 560px;
    margin: 0 auto 40px;
  }

  .value-cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-secondary {
    display: inline-block;
    background: transparent;
    color: var(--mg-subtext);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    padding: 14px 28px;
    border-radius: 4px;
    border: 1px solid #263040;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .cta-secondary:hover {
    border-color: var(--mg-text);
    color: var(--mg-text);
  }

  @media (max-width: 480px) {
    .value-cta-actions {
      flex-direction: column;
      align-items: center;
    }
    .cta-primary,
    .cta-secondary {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }
  }

  /* -------------------------------------------------------
     INSTALL
  ------------------------------------------------------- */
  .install {
    padding: clamp(80px, 12vw, 160px) 0;
    border-bottom: 1px solid var(--mg-surface);
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--mg-surface);
    border: 1px solid #263040;
    border-radius: 6px;
    padding: 18px 24px;
    margin: 0 0 20px;
    max-width: 100%;
  }

  @media (max-width: 560px) {
    .install-block {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
