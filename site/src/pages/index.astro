---
import Base from '../layouts/Base.astro';
import ChromaKeyVideo from '../components/ChromaKeyVideo.tsx';
---

<Base
  title="PrivateEnterprise Enterprise — Your AI Engineering Org"
  description="A complete AI engineering org for every project. 24 agents — CEO, CTO, QA, Dev, Security, Design — led by The Sage. Enterprise-grade drift prevention, session management, and quality enforcement."
>
  <style slot="head">
      /* ── Page-scoped design tokens ────────────────────────────── */
      :root {
        --sage-amber:       #D4A84B;
        --sage-amber-dim:   #6B4E1A;
        --sage-amber-glow:  rgba(212, 168, 75, 0.15);

        /* Text-safe variants — higher lightness for WCAG 4.5:1 on dark backgrounds */
        --mg-guac-text:     #6BBF82;      /* was #4A7C59, lightened for 4.5:1 on #1E2A38 */
        --mg-chili-text:    #E8715F;      /* was #C94D3A, lightened for 4.5:1 on #1E2A38 */
        --mg-cilantro-text: #4CC3C3;      /* was #2E8B8B, lightened for 4.5:1 on #1E2A38 */
      }

      img[data-capy] {
        image-rendering: pixelated;
        image-rendering: crisp-edges;
      }

      /* ── Section shared ───────────────────────────────────────── */
      section { position: relative; padding: 80px 24px; }

      .section-inner {
        max-width: 960px;
        margin: 0 auto;
        width: 100%;
      }

      .section-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--sage-amber);
        margin-bottom: 12px;
      }

      .section-heading {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: var(--mg-text);
        margin-bottom: 16px;
      }

      .section-subhead {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--mg-subtext);
        line-height: 1.6;
        max-width: 520px;
        margin: 0 auto 40px;
      }

      .section-subhead-display {
        font-family: var(--font-display);
        font-size: 1.125rem;
        color: var(--mg-subtext);
        line-height: 1.6;
        max-width: 560px;
        margin-top: 8px;
      }

      .accent-amber  { color: var(--sage-amber); }
      .accent-chili  { color: var(--mg-chili); }
      .accent-guac   { color: var(--mg-guac); }
      .accent-cilantro { color: var(--mg-cilantro); }

      /* ── Scroll-reveal shared ─────────────────────────────────── */
      .reveal { opacity: 0; transition: opacity 0.5s ease var(--reveal-delay, 0ms), transform 0.5s ease var(--reveal-delay, 0ms); }
      .reveal.visible { opacity: 1; transform: none !important; }
      .reveal-up { transform: translateY(16px); }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
        * { animation-duration: 0.01ms !important; }
      }

      /* ── Skip link ────────────────────────────────────────────── */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 9999;
        padding: 8px 16px;
        background: var(--sage-amber);
        color: var(--mg-dark);
        font-family: var(--font-mono);
        font-size: 0.875rem;
        text-decoration: none;
      }
      .skip-link:focus {
        left: 8px;
        top: 8px;
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 1 — HERO
      ══════════════════════════════════════════════════════════ */
      #hero {
        min-height: unset;
        display: flex;
        align-items: flex-start;
        padding: 72px 24px 56px;
        overflow: hidden;
      }

      .hero-inner {
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
        display: grid;
        grid-template-columns: 55% 45%;
        gap: 40px;
        align-items: center;
        position: relative;
      }

      .hero-bg-glow {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(ellipse 600px 500px at 72% 50%, rgba(212,168,75,0.08) 0%, transparent 70%);
        z-index: 0;
      }

      .hero-left {
        position: relative;
        z-index: 1;
        opacity: 0;
        transform: translateY(12px);
        animation: heroLeft 0.6s ease-out 0.1s forwards;
      }

      .hero-right {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: center;
        opacity: 0;
        animation: heroRight 0.7s ease-out 0.2s forwards;
      }

      @keyframes heroLeft {
        to { opacity: 1; transform: none; }
      }
      @keyframes heroRight {
        to { opacity: 1; }
      }

      .hero-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--mg-cilantro-text);
        margin-bottom: 16px;
        display: block;
      }

      .hero-headline {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(3rem, 6vw, 5rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--mg-text);
        margin-bottom: 8px;
      }

      .hero-headline-sub {
        color: var(--mg-cilantro-text);
        font-size: clamp(1.4rem, 3vw, 2.2rem);
        font-weight: 700;
        letter-spacing: 0;
      }

      .hero-lede {
        font-family: var(--font-display);
        font-size: clamp(1rem, 2vw, 1.125rem);
        color: var(--mg-subtext);
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 1rem;
        margin-top: 1.5rem;
      }

      .hero-qualities {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin: 2rem 0;
        border-left: 2px solid var(--mg-cilantro);
        padding-left: 1.5rem;
      }

      .hero-quality {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .hero-quality-word {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 800;
        color: var(--mg-text);
      }

      .hero-quality-desc {
        font-family: var(--font-display);
        font-size: 0.875rem;
        color: var(--mg-subtext);
        line-height: 1.6;
        max-width: 440px;
      }

      .hero-callout {
        background: var(--mg-surface);
        border: 1px solid rgba(46,110,142,0.3);
        border-left: 3px solid var(--mg-cilantro);
        border-radius: 6px;
        padding: 1.25rem 1.5rem;
        max-width: 480px;
        margin-top: 2rem;
        margin-bottom: 1.75rem;
      }

      .hero-callout-label {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-cilantro-text);
        letter-spacing: 0.05em;
        display: block;
        margin-bottom: 0.5rem;
      }

      .hero-callout-body {
        font-family: var(--font-display);
        font-size: 0.875rem;
        color: var(--mg-subtext);
        line-height: 1.65;
      }

      .hero-stat {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-subtext);
        margin-top: 4px;
        margin-bottom: 20px;
      }

      .hero-stat .dot { color: var(--sage-amber); opacity: 0.7; }

      .cta-primary {
        display: inline-block;
        background: var(--mg-lime-zest);
        color: var(--mg-dark);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 12px 28px;
        border-radius: 6px;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s;
        outline-offset: 2px;
      }

      .cta-primary:hover { opacity: 0.9; transform: translateY(-1px); }
      .cta-primary:focus-visible { outline: 2px solid var(--mg-lime-zest); }

      /* Terminal-behind-Sage layered hero */
      .hero-illustration {
        position: relative;
      }

      .hero-img {
        width: 340px;
        max-width: 100%;
        animation: float 6s ease-in-out infinite;
        filter: drop-shadow(0 0 32px rgba(212,168,75,0.25));
        position: relative;
        z-index: 3;
      }

      /* Animated sage video in hero — matches .hero-img sizing */
      :global(.hero-img-video) {
        width: 440px;
        max-width: 100%;
        animation: float 6s ease-in-out infinite;
        filter: drop-shadow(0 0 32px rgba(212,168,75,0.25));
        position: relative;
        z-index: 3;
      }

      :global(.hero-img-video canvas) {
        width: 100%;
        height: auto;
        display: block;
      }

      .hero-terminal-bg {
        position: absolute;
        inset: -20px -30px;
        z-index: 1;
        opacity: 0.13;
        overflow: hidden;
        border-radius: 8px;
        pointer-events: none;
      }

      .hero-terminal-bg pre {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.7rem;
        line-height: 1.75;
        color: #8A9BB0;
        white-space: pre;
        margin: 0;
        padding: 16px;
        animation: terminalScroll 12s linear infinite;
      }

      @keyframes terminalScroll {
        0%   { transform: translateY(0); }
        100% { transform: translateY(-50%); }
      }

      .hero-amber-glow {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        background: radial-gradient(ellipse 260px 280px at 50% 50%, rgba(212,168,75,0.18) 0%, transparent 70%);
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
      }

      /* Constellation particles */
      .particles {
        position: absolute;
        inset: -20px;
        pointer-events: none;
      }

      .particle {
        position: absolute;
        width: 2px;
        height: 2px;
        border-radius: 50%;
        background: rgba(212,168,75,0.3);
        animation: particleFadeIn 0.4s ease forwards, particlePulse var(--dur, 3.5s) ease-in-out var(--delay, 0s) infinite;
        opacity: 0;
      }

      @keyframes particleFadeIn {
        to { opacity: var(--base-opacity, 0.3); }
      }

      @keyframes particlePulse {
        0%, 100% { opacity: var(--base-opacity, 0.3); }
        50%       { opacity: 0.6; }
      }

      .particle-line {
        position: absolute;
        background: rgba(212,168,75,0.2);
        height: 0.5px;
        transform-origin: left center;
        pointer-events: none;
      }

      /* Hero mobile */
      @media (max-width: 767px) {
        .hero-inner {
          grid-template-columns: 1fr;
          grid-template-rows: auto auto;
        }
        .hero-right { order: -1; }
        .hero-img { width: 100%; max-width: 280px; }
        :global(.hero-img-video) { width: 100%; max-width: 320px; }
        #hero { padding: 48px 20px 40px; }
        /* Value props stack on mobile */
        #value-props > .section-inner > ul:first-child {
          grid-template-columns: 1fr !important;
          gap: 24px !important;
        }
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 2 — TEAM HIERARCHY
      ══════════════════════════════════════════════════════════ */
      #hierarchy {
        background: var(--mg-dark);
        text-align: center;
      }

      .hierarchy-wrap {
        max-width: 900px;
        margin: 0 auto;
        position: relative;
      }

      .hierarchy-svg-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: visible;
      }

      .sage-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-bottom: 48px;
        position: relative;
        z-index: 1;
      }

      .sage-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 2px solid var(--sage-amber);
        overflow: hidden;
        background: radial-gradient(circle, rgba(212,168,75,0.3), rgba(212,168,75,0.1));
        box-shadow: 0 0 24px 8px rgba(212,168,75,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      .sage-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        mix-blend-mode: normal;
      }

      .sage-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: var(--mg-subtext);
        text-transform: uppercase;
      }

      /* Tier rows */
      .tier-row {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 32px;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
      }

      /* C-suite nodes */
      .csuite-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 56px;
        background: var(--mg-surface);
        border-radius: 8px;
        border: 1.5px solid;
        cursor: default;
        transition: box-shadow 0.3s, opacity 0.3s, border-color 0.3s;
      }

      .csuite-node .role-abbr {
        font-family: var(--font-mono);
        font-size: 1rem;
        font-weight: 600;
        color: var(--mg-text);
      }

      .csuite-node .role-title {
        font-family: var(--font-display);
        font-size: 0.75rem;
        color: var(--mg-subtext);
        margin-top: 2px;
      }

      .csuite-node[data-role="CEO"] { border-color: var(--mg-subtext); }
      .csuite-node[data-role="CTO"] { border-color: #4A9ABF; }
      .csuite-node[data-role="CMO"] { border-color: #8B4A2E; }
      .csuite-node[data-role="CFO"] { border-color: #7A5C8B; }

      /* Director nodes */
      .dir-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 90px;
        height: 44px;
        background: var(--mg-surface);
        border-radius: 8px;
        border: 1px solid;
      }

      .dir-node .role-abbr {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--mg-text);
      }

      .dir-node .role-title {
        font-family: var(--font-display);
        font-size: 0.65rem;
        color: var(--mg-subtext);
      }

      .dir-node[data-role="EM"]   { border-color: rgba(74,124,89,0.5); }
      .dir-node[data-role="TL"]   { border-color: rgba(74,154,191,0.5); }
      .dir-node[data-role="PO"]   { border-color: rgba(139,74,46,0.5); }
      .dir-node[data-role="QAL"]  { border-color: rgba(122,92,139,0.5); }
      .dir-node[data-role="more"] { border: 1px dashed rgba(138,155,176,0.3); }

      /* IC pills */
      .ic-row {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
        margin-bottom: 16px;
      }

      .ic-pill {
        height: 28px;
        padding: 0 12px;
        border-radius: 14px;
        background: transparent;
        border: 1px solid rgba(138,155,176,0.3);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--mg-subtext);
        display: flex;
        align-items: center;
      }

      .bird-ic {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        margin-top: 16px;
        position: relative;
        z-index: 1;
      }

      .bird-ic img {
        width: 32px;
        height: 32px;
        object-fit: contain;
      }

      .bird-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--mg-subtext);
      }

      /* Screen-reader only table */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
      }

      /* Spawning table below hierarchy */
      .spawning-table-wrap {
        max-width: 900px;
        margin: 48px auto 0;
        text-align: left;
      }

      .spawning-intro {
        font-family: var(--font-display);
        font-size: 1rem;
        color: var(--mg-subtext);
        line-height: 1.7;
        max-width: 620px;
        margin: 0 auto 1.75rem;
        text-align: center;
      }

      .spawning-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        margin-bottom: 1rem;
      }

      .spawning-table thead th {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mg-subtext);
        text-align: left;
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid rgba(46,63,82,0.8);
      }

      .spawning-table tbody tr {
        border-bottom: 1px solid rgba(26,35,50,0.8);
      }

      .spawning-table tbody tr:last-child {
        border-bottom: none;
      }

      .spawning-table tbody td {
        padding: 0.875rem 0.75rem;
        color: var(--mg-text);
        font-size: 0.9rem;
        vertical-align: middle;
      }

      .spawn-tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: var(--mg-surface);
        border: 1px solid var(--mg-cilantro);
        border-radius: 3px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-cilantro-text);
        margin-right: 0.35rem;
      }

      .spawning-note {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-subtext);
        opacity: 0.8;
        margin-top: 0.75rem;
        text-align: center;
      }

      @media (max-width: 767px) {
        .sage-circle { width: 60px; height: 60px; }
        .csuite-node { width: 90px; height: 48px; }
        .tier-row { gap: 10px; }
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 3 — SELECTIVE SPAWNING
      ══════════════════════════════════════════════════════════ */
      #spawning { background: var(--mg-dark); }

      .spawning-panel {
        background: var(--mg-surface);
        border: 1px solid rgba(138,155,176,0.15);
        border-radius: 12px;
        padding: 32px;
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 35% 65%;
        gap: 32px;
        position: relative;
      }

      .spawning-left .scenario-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mg-subtext);
        margin-bottom: 12px;
      }

      .scenario-tabs {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 20px;
      }

      .scenario-tab {
        padding: 10px 16px;
        border-radius: 8px;
        background: transparent;
        border: 1px solid rgba(138,155,176,0.2);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-subtext);
        cursor: pointer;
        text-align: left;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
      }

      .scenario-tab[aria-checked="true"] {
        background: rgba(46,139,139,0.15);
        border-color: var(--mg-cilantro);
        color: var(--mg-text);
      }

      .task-sample-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--mg-subtext);
        margin-bottom: 6px;
      }

      .task-description {
        border-left: 2px solid var(--mg-cilantro);
        padding-left: 12px;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-subtext);
        line-height: 1.5;
        transition: opacity 0.3s;
      }

      .spawning-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
      }

      .spawn-sage-node {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        border: 2px solid var(--sage-amber);
        overflow: hidden;
        background: radial-gradient(circle, var(--sage-amber), rgba(212,168,75,0.4));
        box-shadow: 0 0 16px 4px rgba(212,168,75,0.3);
        margin-bottom: 32px;
        transition: box-shadow 0.4s;
        position: relative;
        z-index: 1;
      }

      .spawn-sage-node.pulsing {
        box-shadow: 0 0 32px 12px rgba(212,168,75,0.5);
      }

      .spawn-sage-node img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        mix-blend-mode: screen;
      }

      .spawn-csuite-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
        position: relative;
        z-index: 1;
      }

      .spawn-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100px;
        height: 52px;
        background: var(--mg-surface);
        border-radius: 8px;
        border: 1.5px solid;
        transition: border-color 0.3s, opacity 0.3s, box-shadow 0.3s;
      }

      .spawn-node .role-abbr {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--mg-text);
        transition: opacity 0.3s;
      }

      .spawn-node .role-title {
        font-family: var(--font-display);
        font-size: 0.65rem;
        color: var(--mg-subtext);
        transition: opacity 0.3s;
      }

      .spawn-node[data-role="CEO"] { border-color: var(--mg-subtext); }
      .spawn-node[data-role="CTO"] { border-color: #4A9ABF; }
      .spawn-node[data-role="CMO"] { border-color: #8B4A2E; }
      .spawn-node[data-role="CFO"] { border-color: #7A5C8B; }

      .spawn-node[data-role="CEO"].active { box-shadow: 0 0 12px 3px rgba(138,155,176,0.3); }
      .spawn-node[data-role="CTO"].active { box-shadow: 0 0 12px 3px rgba(74,154,191,0.3); }
      .spawn-node[data-role="CMO"].active { box-shadow: 0 0 12px 3px rgba(139,74,46,0.3); }
      .spawn-node[data-role="CFO"].active { box-shadow: 0 0 12px 3px rgba(122,92,139,0.3); }

      .spawn-node.dormant {
        border-color: rgba(138,155,176,0.2);
        border-style: dashed;
        box-shadow: none;
      }

      .spawn-node.dormant .role-abbr { opacity: 0.25; }
      .spawn-node.dormant .role-title { opacity: 0; }

      .spawn-lines-svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
      }

      .spawning-section-wrap {
        position: relative;
      }

      .teacher-wrap {
        position: absolute;
        bottom: -40px;
        right: 0;
        display: flex;
        align-items: flex-end;
        gap: 8px;
        pointer-events: none;
      }

      .teacher-bird { width: 24px; height: 24px; object-fit: contain; }
      .teacher-img  { width: 120px; height: auto; object-fit: contain; }

      @media (max-width: 767px) {
        .spawning-panel {
          grid-template-columns: 1fr;
          padding: 20px;
          overflow: hidden;
        }
        .teacher-wrap { display: none; }
        .spawn-node {
          width: 60px;
          min-width: 60px;
          padding: 6px 4px;
        }
        .spawn-node .role-abbr { font-size: 0.75rem; }
        .spawn-node .role-title { font-size: 0.55rem; }
        .scenario-tabs {
          flex-direction: row;
          flex-wrap: nowrap;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          gap: 8px;
          padding-bottom: 4px;
          scrollbar-width: none;
        }
        .scenario-tabs::-webkit-scrollbar { display: none; }
        .scenario-tab { white-space: nowrap; min-width: 110px; font-size: 0.75rem; }
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 4 — DRIFT DETECTION
      ══════════════════════════════════════════════════════════ */
      #drift { background: var(--mg-dark); }

      .drift-stat-callout {
        text-align: center;
        margin: 16px 0 40px;
      }

      .drift-stat-number {
        font-family: var(--font-mono);
        font-size: 3rem;
        font-weight: 600;
        color: var(--sage-amber);
        line-height: 1;
      }

      .drift-stat-desc {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--mg-subtext);
        margin-top: 6px;
      }

      .drift-panels {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 900px;
        margin: 0 auto;
      }

      .drift-panel {
        background: var(--mg-surface);
        border: 1px solid rgba(138,155,176,0.15);
        border-radius: 12px;
        padding: 28px;
        position: relative;
        overflow: hidden;
      }

      .drift-panel.bad {
        background: linear-gradient(180deg, rgba(201,77,58,0.04) 0%, transparent 60%), var(--mg-surface);
      }

      .drift-panel.good {
        background: linear-gradient(180deg, rgba(74,124,89,0.06) 0%, transparent 60%), var(--mg-surface);
      }

      .drift-panel-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 20px;
      }

      .drift-panel.bad .drift-panel-label  { color: var(--mg-chili-text); }
      .drift-panel.good .drift-panel-label { color: var(--mg-guac-text); }

      .pipeline-wrap {
        position: relative;
        display: flex;
        gap: 12px;
      }

      .pipeline-nodes {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .pipeline-node {
        height: 40px;
        border-radius: 6px;
        border: 1.5px solid;
        display: flex;
        align-items: center;
        padding: 0 12px;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-text);
        position: relative;
      }

      .pipeline-arrow {
        width: 14px;
        position: absolute;
        right: -6px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.7rem;
        color: var(--mg-subtext);
        opacity: 0.4;
        pointer-events: none;
      }

      /* Left panel node borders */
      .bad .pn-commit  { border-color: rgba(138,155,176,0.3); }
      .bad .pn-ci      { border-color: rgba(138,155,176,0.3); }
      .bad .pn-review  { border-color: rgba(201,77,58,0.6); }
      .bad .pn-staging { border-color: rgba(201,77,58,0.8); }
      .bad .pn-prod    { border-color: rgba(201,77,58,1.0); }

      /* Right panel node borders */
      .good .pn-commit  { border-color: rgba(138,155,176,0.3); }
      .good .pn-ci      { border-color: rgba(138,155,176,0.3); }
      .good .pn-review  { border-color: rgba(212,168,75,0.8); }
      .good .pn-staging { border-color: rgba(74,124,89,0.5); }
      .good .pn-prod    { border-color: rgba(74,124,89,0.7); }

      .drift-arrows-col {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding-top: 92px;
        align-items: center;
      }

      .drift-arrows-col path { stroke: var(--mg-chili); }
      .drift-arrows-col polygon { fill: var(--mg-chili); }

      .drift-arrow-item {
        color: var(--mg-chili);
        font-size: 0.7rem;
        opacity: 0.85;
      }

      .drift-problem-tag {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: rgba(var(--mg-chili-rgb, 201,77,58),0.7);
        margin-top: 2px;
        padding-left: 4px;
      }

      .bird-lost {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        margin-top: 16px;
      }

      .bird-lost img {
        width: 28px;
        transform: rotate(-15deg) scaleX(-1);
        filter: brightness(0.85);
      }

      .bird-lost-label {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--mg-subtext);
      }

      .sage-interception {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
      }

      .sage-intercept-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }

      .sage-intercept-label {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--sage-amber);
      }

      .bird-guided {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        margin-top: 16px;
      }

      .bird-guided img { width: 28px; }

      .bird-guided-label {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--mg-subtext);
      }

      .sage-mini-panel {
        text-align: center;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid rgba(138,155,176,0.1);
      }

      .sage-mini-panel img {
        width: 56px;
        filter: drop-shadow(0 0 8px rgba(212,168,75,0.4));
      }

      /* Drift narrative below panels */
      .drift-narrative {
        max-width: 900px;
        margin: 40px auto 0;
      }

      .drift-compare-strip {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 32px;
      }

      .drift-tier {
        padding: 1.25rem 1.5rem;
        border-radius: 6px;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .drift-tier-community {
        background: var(--mg-surface);
        border: 1px solid rgba(46,63,82,0.8);
      }

      .drift-tier-enterprise {
        background: rgba(14,24,32,0.8);
        border: 1px solid var(--mg-cilantro);
      }

      .drift-tier-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .drift-tier-community .drift-tier-label { color: var(--mg-subtext); }
      .drift-tier-enterprise .drift-tier-label { color: var(--mg-cilantro-text); }

      .drift-tier-body {
        font-size: 0.9rem;
        color: var(--mg-subtext);
        line-height: 1.65;
      }

      .drift-tier-verdict {
        font-family: var(--font-display);
        font-size: 0.875rem;
        font-weight: 700;
      }

      .drift-tier-community .drift-tier-verdict { color: var(--mg-subtext); }
      .drift-tier-enterprise .drift-tier-verdict { color: var(--mg-cilantro-text); }

      .metrics-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
        margin-bottom: 2.5rem;
      }

      .metric-card {
        background: var(--mg-surface);
        border: 1px solid rgba(46,63,82,0.8);
        border-radius: 6px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .metric-num {
        font-family: var(--font-display);
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--mg-text);
        line-height: 1;
        letter-spacing: -0.02em;
      }

      .metric-label {
        font-family: var(--font-display);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--mg-cilantro-text);
      }

      .metric-context {
        font-size: 0.8125rem;
        color: var(--mg-subtext);
        line-height: 1.6;
        margin-top: 0.25rem;
      }

      .cascade-story {
        background: rgba(14,24,32,0.8);
        border: 1px solid rgba(46,63,82,0.8);
        border-radius: 6px;
        padding: 2rem 2.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .story-heading {
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--mg-text);
      }

      .story-body {
        font-size: 0.9375rem;
        color: var(--mg-subtext);
        line-height: 1.75;
      }

      .sage-quote {
        border-left: 2px solid var(--mg-cilantro);
        padding: 0.75rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-top: 0.5rem;
        background: var(--mg-surface);
        border-radius: 0 4px 4px 0;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--mg-text);
        line-height: 1.7;
        font-style: normal;
      }

      .quote-prefix {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-cilantro-text);
        letter-spacing: 0.06em;
      }

      @media (max-width: 767px) {
        .drift-panels { grid-template-columns: 1fr; }
        .pipeline-node { height: 34px; font-size: 0.75rem; }
        .drift-compare-strip { grid-template-columns: 1fr; }
        .metrics-grid { grid-template-columns: 1fr; }
      }

      /* Drift mobile narrative helpers */
      .drift-mobile-intro {
        display: none;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--mg-subtext);
        text-align: center;
        font-style: italic;
        margin: 0 auto 24px;
        max-width: 360px;
      }

      .drift-vs-connector {
        display: none;
        align-items: center;
        justify-content: center;
        padding: 4px 0;
      }

      .drift-vs-badge {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--sage-amber-glow);
        border: 1.5px solid var(--sage-amber);
        box-shadow: 0 0 12px 4px rgba(212,168,75,0.18);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0;
      }

      .drift-vs-badge .vs-text {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--sage-amber);
        line-height: 1;
      }

      .drift-vs-badge .vs-sub {
        font-family: var(--font-mono);
        font-size: 0.5rem;
        color: var(--mg-subtext);
        line-height: 1;
        margin-top: 2px;
        white-space: nowrap;
      }

      @media (max-width: 767px) {
        .drift-mobile-intro { display: block; }
        .drift-vs-connector  { display: flex; }
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 4b — HOW IT WORKS (CAPABILITIES)
      ══════════════════════════════════════════════════════════ */
      #capabilities { background: var(--mg-dark); }

      .capability-stack {
        display: flex;
        flex-direction: column;
        gap: 0;
        max-width: 760px;
        margin: 0 auto 3.5rem;
      }

      .capability {
        display: grid;
        grid-template-columns: 3.5rem 1fr;
        gap: 1.5rem;
        padding: 2.25rem 0;
        border-top: 1px solid rgba(26,35,50,0.8);
      }

      .capability:first-child { border-top: none; }

      .cap-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        padding-top: 0.2rem;
      }

      .cap-num {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-cilantro-text);
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
      }

      .cap-line {
        width: 1px;
        flex: 1;
        background: rgba(46,63,82,0.8);
        min-height: 2rem;
      }

      .cap-content {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
      }

      .cap-heading {
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--mg-text);
      }

      .cap-body {
        font-size: 0.9375rem;
        color: var(--mg-subtext);
        line-height: 1.75;
      }

      .cap-detail { margin-top: 0.25rem; }

      .detail-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-cilantro-text);
        letter-spacing: 0.06em;
        margin-bottom: 0.625rem;
      }

      .detail-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        padding: 0;
        margin: 0;
      }

      .detail-list li {
        font-size: 0.875rem;
        color: var(--mg-subtext);
        padding-left: 1.25rem;
        position: relative;
        line-height: 1.55;
      }

      .detail-list li::before {
        content: '—';
        position: absolute;
        left: 0;
        color: var(--mg-cilantro-text);
        font-family: var(--font-mono);
      }

      .cap-snapshot {
        background: var(--mg-dark);
        border: 1px solid rgba(46,63,82,0.8);
        border-radius: 4px;
        padding: 1rem 1.25rem;
      }

      .snapshot-pre {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mg-subtext);
        line-height: 1.65;
        white-space: pre;
        margin-top: 0.625rem;
        overflow-x: auto;
      }

      .benchmark-callout {
        background: var(--mg-surface);
        border: 1px solid rgba(46,63,82,0.8);
        border-radius: 6px;
        padding: 2rem 2.25rem;
        max-width: 760px;
        margin: 0 auto;
      }

      .bench-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--mg-subtext);
        margin-bottom: 1.5rem;
      }

      .bench-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .bench-item {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .bench-metric {
        font-family: var(--font-display);
        font-size: 1.375rem;
        font-weight: 800;
        color: var(--mg-cilantro-text);
        line-height: 1.1;
      }

      .bench-desc {
        font-size: 0.8125rem;
        color: var(--mg-subtext);
        line-height: 1.6;
      }

      @media (max-width: 640px) {
        .capability { grid-template-columns: 2.5rem 1fr; gap: 1rem; }
        .bench-grid { grid-template-columns: 1fr; }
      }

      /* ══════════════════════════════════════════════════════════
         SECTION 5 — SESSION MANAGEMENT
      ══════════════════════════════════════════════════════════ */
      #sessions { background: var(--mg-dark); }

      .session-timeline {
        display: flex;
        align-items: stretch;
        gap: 0;
        max-width: 960px;
        margin: 40px auto 0;
        position: relative;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .session-block {
        width: 200px;
        min-height: 220px;
        background: var(--mg-surface);
        border: 1px solid rgba(138,155,176,0.2);
        border-radius: 12px;
        padding: 16px;
        position: relative;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
      }

      .session-block.active {
        border-left: 3px solid var(--sage-amber);
        box-shadow: 0 0 16px 4px rgba(212,168,75,0.1);
      }

      .session-num {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--mg-subtext);
        margin-bottom: 8px;
      }

      .session-divider {
        height: 1px;
        background: rgba(138,155,176,0.15);
        margin-bottom: 10px;
      }

      .session-work {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--mg-text);
        line-height: 1.6;
        flex: 1;
      }

      .session-sage-avatar {
        position: absolute;
        bottom: 10px;
        right: 10px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        overflow: hidden;
        background: rgba(212,168,75,0.2);
        border: 1px solid var(--sage-amber);
      }

      .session-sage-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        mix-blend-mode: screen;
      }

      .session-status {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        padding: 2px 8px;
        border-radius: 10px;
        margin-top: 10px;
      }

      .status-completed {
        background: rgba(74,124,89,0.15);
        color: var(--mg-guac-text);
      }

      .status-inprogress {
        background: rgba(212,168,75,0.12);
        color: var(--sage-amber);
      }

      /* Bridge connector */
      .session-bridge {
        width: 120px;
        min-height: 220px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        position: relative;
        padding: 16px 8px;
      }

      .bridge-line {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        width: 1px;
        background: repeating-linear-gradient(
          to bottom,
          rgba(46,139,139,0.3) 0px,
          rgba(46,139,139,0.3) 6px,
          transparent 6px,
          transparent 12px
        );
        transform: translateX(-50%);
      }

      .bridge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--sage-amber);
        position: relative;
        z-index: 1;
        animation: bridgePulse 3s ease-in-out infinite;
      }

      .bridge-dot::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        background: rgba(212,168,75,0.15);
        opacity: 0;
        animation: bridgeGlowPulse 3s ease-in-out infinite;
      }

      @keyframes bridgeGlowPulse {
        50% { opacity: 1; }
      }

      @keyframes bridgePulse {
        0%, 100% { opacity: 0.6; }
        50%       { opacity: 1; }
      }

      .bridge-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--mg-subtext);
        text-align: center;
        position: relative;
        z-index: 1;
      }

      .bridge-sublabels {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: rgba(138,155,176,0.5);
        text-align: center;
        line-height: 1.5;
        position: relative;
        z-index: 1;
      }

      .bridge-bird {
        width: 20px;
        height: 20px;
        object-fit: contain;
        position: relative;
        z-index: 1;
      }

      .bridge-bird-label {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--mg-subtext);
        position: relative;
        z-index: 1;
      }

      .bridge-monk {
        width: 72px;
        height: auto;
        object-fit: contain;
        position: relative;
        z-index: 1;
        filter: drop-shadow(0 0 8px rgba(212,168,75,0.4));
      }

      .session-annotation {
        max-width: 680px;
        margin: 40px auto 0;
        text-align: center;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--mg-subtext);
        line-height: 1.7;
        padding: 0 16px;
      }

      @media (max-width: 900px) {
        .session-timeline {
          flex-direction: column;
          align-items: center;
          gap: 0;
        }

        .session-block {
          width: 100%;
          max-width: 400px;
          min-height: auto;
        }

        .session-bridge {
          width: 100%;
          max-width: 400px;
          min-height: 80px;
          flex-direction: row;
