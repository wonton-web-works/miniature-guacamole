<script define:vars={{ fundMap: JSON.stringify(fundMap) }}>
  /*
   * INVITE-ONLY MARKETING GATE — NOT A SECURITY BOUNDARY.
   * Same pattern as /pilot. Client-side gating for casual access control.
   */

  const FALLBACK_CODE = 'invest2026';
  const funds = JSON.parse(fundMap);

  // Build a code → fund slug lookup from all fund profiles
  const codeLookup = {};
  for (const [slug, fund] of Object.entries(funds)) {
    if (fund.access_code) {
      codeLookup[fund.access_code.toLowerCase()] = slug;
    }
  }

  const form = document.getElementById('verify-form');
  const input = document.getElementById('code-input');
  const errorEl = document.getElementById('gate-error');
  const gate = document.getElementById('gate');
  const deck = document.getElementById('deck');

  let matchedFundSlug = null;

  form.addEventListener('submit', () => {
    const code = input.value.trim().toLowerCase();

    // Check per-fund codes first, then fallback
    if (codeLookup[code]) {
      matchedFundSlug = codeLookup[code];
      gate.style.display = 'none';
      deck.removeAttribute('aria-hidden');
      deck.classList.add('fade-in');
      loadFundProfile(matchedFundSlug);
      window.plausible?.('Investor Unlock', { props: { fund: matchedFundSlug } });
    } else if (code === FALLBACK_CODE) {
      gate.style.display = 'none';
      deck.removeAttribute('aria-hidden');
      deck.classList.add('fade-in');
      // Check URL param as before
      const params = new URLSearchParams(window.location.search);
      const fundParam = params.get('fund');
      if (fundParam) loadFundProfile(fundParam);
      window.plausible?.('Investor Unlock', { props: { fund: 'general' } });
    } else {
      errorEl.textContent = 'Invalid access code. Check your invite.';
      input.focus();
    }
  });

  input.addEventListener('input', () => {
    errorEl.textContent = '';
  });

  function loadFundProfile(slug) {
    if (!slug || !funds[slug]) return;

    const fund = funds[slug];
    if (!fund.fund_name) return;

    // Helper: safe textContent update
    function setText(id, text) {
      const el = document.getElementById(id);
      if (el && text) el.textContent = text;
    }
    function show(id) {
      const el = document.getElementById(id);
      if (el) el.style.display = 'block';
    }

    // ── Cover slide: "Prepared for [Fund Name]" ──
    setText('cover-fund', `Prepared for ${fund.fund_name}`);
    show('cover-fund');

    // ── Cover slide: raise amount ──
    if (fund.raise) {
      setText('cover-raise', `${fund.raise.amount} Seed  |  March 2026`);
    }

    // ── Business model slide: fund thesis alignment ──
    if (fund.body) {
      const fundThesis = document.getElementById('fund-thesis');
      const fundThesisBody = document.getElementById('fund-thesis-body');
      if (fundThesis && fundThesisBody) {
        fundThesisBody.textContent = fund.body;
        fundThesis.style.display = 'block';
      }
    }

    // ── The Ask slide ──
    if (fund.raise) {
      setText('ask-headline', `${fund.raise.amount} to own the AI org layer.`);
      setText('ask-raise-line', `${fund.raise.amount} Seed  |  ${fund.raise.pre_money} Pre-Money`);
    }
    if (fund.fund_name) {
      const askFundLine = document.getElementById('ask-fund-line');
      if (askFundLine) {
        askFundLine.textContent = `We'd be proud to build this with ${fund.fund_name}.`;
        askFundLine.style.display = 'block';
      }
    }

    // ── Financial model slide ──
    if (fund.financials) {
      const f = fund.financials;
      setText('fin-y1-base', f.y1_base_arr);
      setText('fin-y2-base', f.y2_base_arr);
      setText('fin-y3-base', f.y3_base_arr);
      setText('fin-y1-expected', f.y1_expected_arr);
      setText('fin-y2-expected', f.y2_expected_arr);
      setText('fin-y3-expected', f.y3_expected_arr);
      setText('fin-cashflow', f.cashflow_positive);
      setText('fin-min-cash', f.min_cash);
      setText('fin-series-a', f.series_a);
    }

    // ── Returns slide ──
    if (fund.returns) {
      const r = fund.returns;
      setText('ret-base-arr', r.base_exit_arr);
      setText('ret-base-mult', r.base_multiple);
      setText('ret-base-return', `${r.base_return} — ${r.base_return_dollar}`);
      setText('ret-exp-arr', r.expected_exit_arr);
      setText('ret-exp-mult', r.expected_multiple);
      setText('ret-exp-return', `${r.expected_return} — ${r.expected_return_dollar}`);
      setText('ret-upside-arr', r.upside_exit_arr);
      setText('ret-upside-mult', r.upside_multiple);
      setText('ret-upside-return', r.upside_return);
      setText('ev-val', r.ev_weighted);
      // Update returns headline
      setText('returns-headline', `${fund.raise.amount} at ${fund.raise.pre_money} pre. Base case: ${r.base_return}.`);
    }

    // ── Update metrics grid ──
    if (fund.metrics) {
      const grid = document.getElementById('metrics-grid');
      if (grid) {
        grid.replaceChildren();
        fund.metrics.forEach((m) => {
          const item = document.createElement('div');
          item.className = 'metric-item';
          const val = document.createElement('span');
          val.className = 'metric-value';
          val.textContent = m.value;
          const label = document.createElement('span');
          label.className = 'metric-label';
          label.textContent = m.label;
          item.appendChild(val);
          item.appendChild(label);
          grid.appendChild(item);
        });
      }
    }
  }

  // Investor CTA form submission
  const ctaForm = document.getElementById('investor-cta-form');
  const ctaBtn = document.getElementById('investor-submit');
  const ctaSuccess = document.getElementById('investor-success');

  ctaForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!ctaBtn || !ctaForm) return;
    ctaBtn.disabled = true;
    ctaBtn.textContent = 'Sending...';
    try {
      const res = await fetch(ctaForm.action, {
        method: 'POST',
        body: new FormData(ctaForm),
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        ctaForm.style.display = 'none';
        if (ctaSuccess) ctaSuccess.style.display = 'block';
        window.plausible?.('Investor Form', { props: { source: 'investor-page' } });
      } else {
        ctaBtn.textContent = 'Error — try again';
        ctaBtn.disabled = false;
      }
    } catch {
      ctaBtn.textContent = 'Error — try again';
      ctaBtn.disabled = false;
    }
  });
</script>

