    gap: 1rem;
  }

  .bench-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    min-width: 220px;
    flex-shrink: 0;
  }

  .bench-bar-wrap {
    flex: 1;
    height: 6px;
    background: #1A2232;
    border-radius: 3px;
    overflow: hidden;
  }

  .bench-bar {
    height: 100%;
    background: var(--mg-subtext);
    border-radius: 3px;
    transition: width 0.6s ease;
  }

  .bench-bar.highlight {
    background: #D4A84B;
  }

  .bench-score {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    min-width: 3rem;
    text-align: right;
  }

  .bench-note {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    font-style: italic;
    margin-top: 0;
  }

  /* Benchmark methodology expandable */
  .bench-methodology {
    margin-top: 1.25rem;
    border: 1px solid rgba(46,63,82,0.4);
    border-radius: 8px;
    overflow: hidden;
  }

  .bench-methodology-toggle {
    display: block;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--mg-cilantro);
    cursor: pointer;
    letter-spacing: 0.04em;
    list-style: none;
  }

  .bench-methodology-toggle::-webkit-details-marker { display: none; }
  .bench-methodology-toggle::before {
    content: '+ ';
    font-weight: 700;
  }
  details[open] .bench-methodology-toggle::before {
    content: '− ';
  }

  .bench-methodology-content {
    padding: 0 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .bench-methodology-intro {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    line-height: 1.65;
  }

  .bench-section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mg-cilantro);
    margin-bottom: 0.75rem;
  }

  .bench-task-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bench-task-item {
    display: grid;
    grid-template-columns: 2.5rem 8rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .bench-task-weight {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #D4A84B;
    font-weight: 700;
  }

  .bench-task-name {
    font-weight: 600;
    color: var(--mg-text);
  }

  .bench-task-desc {
    color: var(--mg-subtext);
    font-size: 0.75rem;
  }

  .bench-config-table {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bench-config-row {
    display: grid;
    grid-template-columns: 3rem 1fr 4rem 4rem;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(46,63,82,0.2);
    font-size: 0.8125rem;
    color: var(--mg-text);
    align-items: center;
  }

  .bench-config-row.header {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mg-subtext);
    border-bottom: 1px solid rgba(46,63,82,0.4);
  }

  .bench-config-row.highlight-row {
    background: rgba(212, 168, 75, 0.04);
  }

  .bench-insight {
    background: var(--mg-surface);
    border: 1px solid rgba(46,63,82,0.4);
    border-left: 3px solid var(--mg-cilantro);
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .bench-insight-text {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    line-height: 1.65;
  }

  .bench-insight-text strong {
    color: var(--mg-text);
  }

  @media (max-width: 480px) {
    .bench-task-item {
      grid-template-columns: 2.5rem 1fr;
    }
    .bench-task-desc {
      grid-column: 1 / -1;
    }
    .bench-config-row {
      grid-template-columns: 2rem 1fr 3.5rem 3.5rem;
      font-size: 0.75rem;
    }
  }

  .moat-layers {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .moat-layer {
    display: grid;
    grid-template-columns: 60px 160px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.875rem 0;
    border-bottom: 1px solid #1E2A38;
  }

  .moat-layer:last-child {
    border-bottom: none;
  }

  .moat-tier {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--mg-subtext);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .moat-tier.highlight { color: #D4A84B; }

  .moat-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--mg-text);
  }

  .moat-name.highlight { color: #D4A84B; }

  .moat-desc {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    line-height: 1.5;
  }

  /* ================================================================
     SLIDE 7: MARKET
  ================================================================ */

  .tam-block {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .tam-ring {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    position: relative;
    text-align: center;
  }

  .tam-3 {
    width: 280px;
    height: 280px;
    background: rgba(46, 139, 139, 0.08);
    border: 1px solid rgba(46, 139, 139, 0.3);
  }

  .tam-2 {
    width: 200px;
    height: 200px;
    background: rgba(46, 139, 139, 0.12);
    border: 1px solid rgba(46, 139, 139, 0.4);
  }

  .tam-1 {
    width: 130px;
    height: 130px;
    background: rgba(212, 168, 75, 0.12);
    border: 1px solid rgba(212, 168, 75, 0.5);
  }

  .tam-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mg-subtext);
    display: block;
    position: absolute;
    top: 10px;
  }

  .tam-val {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--mg-text);
    display: block;
  }

  .tam-sub {
    font-size: 0.625rem;
    color: var(--mg-subtext);
    display: block;
    line-height: 1.3;
  }

  .comp-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #2E3F52;
    border-radius: 6px;
    overflow: hidden;
  }

  .comp-header,
  .comp-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.25fr 1.25fr 1fr;
    gap: 0;
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    align-items: center;
  }

  .comp-header {
    background: #1A2232;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mg-subtext);
    border-bottom: 1px solid #2E3F52;
  }

  .comp-row {
    border-bottom: 1px solid #1E2A38;
    color: var(--mg-text);
  }

  .comp-row:last-child {
    border-bottom: none;
  }

  .comp-row.muted {
    color: var(--mg-subtext);
  }

  .comp-row.highlight-row {
    background: rgba(212, 168, 75, 0.05);
  }

  .bad-x { color: #E8715F; }

  /* ================================================================
     SLIDE 8: BUSINESS MODEL
  ================================================================ */

  .tier-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .tier-card {
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 8px;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
  }

  .tier-card.highlight-card {
    border-color: #D4A84B;
    background: rgba(212, 168, 75, 0.05);
  }

  .tier-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: #D4A84B;
    color: #0D1117;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  .tier-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--mg-text);
    margin-top: 0.5rem;
  }

  .tier-price {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: #D4A84B;
    line-height: 1;
  }

  .tier-period {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--mg-subtext);
  }

  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .tier-features li {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    padding-left: 1rem;
    position: relative;
  }

  .tier-features li::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--mg-cilantro);
    font-family: var(--font-mono);
  }

  .unit-econ {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .ue-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem;
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 6px;
  }

  .ue-item.highlight {
    border-color: rgba(212, 168, 75, 0.4);
  }

  .ue-val {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--mg-text);
  }

  .ue-item.highlight .ue-val {
    color: #D4A84B;
  }

  .ue-label {
    font-size: 0.75rem;
    color: var(--mg-subtext);
    line-height: 1.3;
  }

  .fund-thesis {
    background: rgba(46, 139, 139, 0.06);
    border: 1px solid rgba(46, 139, 139, 0.25);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-top: 1.5rem;
  }

  .fund-thesis-body {
    font-size: 0.9375rem;
    color: var(--mg-text);
    line-height: 1.65;
  }

  /* ================================================================
     SLIDE 9: FINANCIALS
  ================================================================ */

  .fin-table {
    display: flex;
    flex-direction: column;
    border: 1px solid #2E3F52;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .fin-header,
  .fin-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    align-items: center;
  }

  .fin-header {
    background: #1A2232;
    color: var(--mg-subtext);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid #2E3F52;
  }

  .fin-row {
    border-bottom: 1px solid #1E2A38;
    color: var(--mg-text);
  }

  .fin-row:last-child {
    border-bottom: none;
  }

  .fin-row.highlight-row {
    background: rgba(212, 168, 75, 0.05);
  }

  .fin-scenario.muted   { color: var(--mg-subtext); }
  .fin-scenario.highlight { color: #D4A84B; }

  .fin-callouts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .fin-callout {
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .fin-callout.highlight {
    border-color: rgba(212, 168, 75, 0.4);
    background: rgba(212, 168, 75, 0.04);
  }

  .fin-callout-val {
    font-family: var(--font-mono);
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--mg-text);
  }

  .fin-callout.highlight .fin-callout-val {
    color: #D4A84B;
  }

  .fin-callout-label {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
  }

  /* ================================================================
     SLIDE 10: TRACTION
  ================================================================ */

  .traction-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .traction-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .traction-col-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mg-cilantro);
  }

  .traction-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .traction-list li {
    font-size: 0.875rem;
    color: var(--mg-text);
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }

  .traction-list li::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--mg-cilantro);
    font-family: var(--font-mono);
  }

  .timeline {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 1.5rem 0;
    overflow-x: auto;
  }

  .tl-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .tl-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--mg-surface);
    border: 2px solid var(--mg-subtext);
  }

  .tl-dot.active {
    background: #D4A84B;
    border-color: #D4A84B;
  }

  .tl-dot.future {
    background: transparent;
    border-color: #2E3F52;
    border-style: dashed;
  }

  .tl-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--mg-subtext);
  }

  .tl-label.active  { color: #D4A84B; }
  .tl-label.future  { color: #2E3F52; }

  .tl-desc {
    font-size: 0.6875rem;
    color: var(--mg-subtext);
    text-align: center;
    max-width: 100px;
    line-height: 1.3;
  }

  .tl-line {
    flex: 1;
    height: 1px;
    background: #2E3F52;
    min-width: 2rem;
    align-self: flex-start;
    margin-top: 0.625rem;
  }

  /* ================================================================
     SLIDE 11: RETURNS
  ================================================================ */

  .returns-table {
    display: flex;
    flex-direction: column;
    border: 1px solid #2E3F52;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .ret-header,
  .ret-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1.25fr;
    padding: 0.875rem 1.25rem;
    font-size: 0.875rem;
    align-items: center;
  }

  .ret-header {
    background: #1A2232;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mg-subtext);
    border-bottom: 1px solid #2E3F52;
  }

  .ret-row {
    border-bottom: 1px solid #1E2A38;
    color: var(--mg-text);
  }

  .ret-row:last-child {
    border-bottom: none;
  }

  .ret-row.highlight-row {
    background: rgba(212, 168, 75, 0.05);
  }

  .ret-scenario.muted     { color: var(--mg-subtext); }
  .ret-scenario.highlight { color: #D4A84B; }

  .ret-val {
    font-family: var(--font-mono);
    font-weight: 700;
    color: #D4A84B;
  }

  .ev-callout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--mg-surface);
    border: 1px solid rgba(212, 168, 75, 0.4);
    border-radius: 6px;
    padding: 1rem 1.5rem;
    margin-bottom: 1rem;
  }

  .ev-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ev-val {
    font-family: var(--font-mono);
    font-size: 2.75rem;
    font-weight: 700;
    color: #D4A84B;
  }

  /* ================================================================
     SLIDE 12: TEAM
  ================================================================ */

  .founder-block {
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 6px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .founder-bio {
    font-size: 1rem;
    color: var(--mg-text);
    line-height: 1.7;
  }

  .hire-plan {
    background: rgba(46, 139, 139, 0.04);
    border: 1px solid rgba(46, 139, 139, 0.2);
    border-radius: 6px;
    padding: 1.5rem;
  }

  .hire-timeline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hire-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 6px;
    padding: 0.625rem 0.875rem;
    min-width: 110px;
  }

  .hire-when {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--mg-cilantro);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hire-role {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--mg-text);
  }

  .hire-arrow {
    color: var(--mg-subtext);
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* ================================================================
     SLIDE 13: THE ASK
  ================================================================ */

  .ask-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .ask-card {
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 8px;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ask-card.highlight-card {
    border-color: #D4A84B;
    background: rgba(212, 168, 75, 0.06);
  }

  .ask-card-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--mg-subtext);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ask-card-val {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--mg-text);
  }

  .ask-card.highlight-card .ask-card-val {
    color: #D4A84B;
  }

  .ask-card-sub {
    font-size: 0.8125rem;
    color: var(--mg-subtext);
    line-height: 1.4;
  }

  .ask-path {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .path-item {
    flex: 1;
    min-width: 150px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem 1rem;
    background: var(--mg-surface);
    border: 1px solid #2E3F52;
    border-radius: 6px;
  }

  .path-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--mg-subtext);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .path-val {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 700;
    color: #D4A84B;
  }

  .ask-cta-line {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--mg-text);
    margin-bottom: 1rem;
  }

  .ask-fund-line {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--mg-cilantro);
    margin-bottom: 2rem;
  }

  .cta-block {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #1E2A38;
  }

  .investor-success {
    color: var(--mg-cilantro);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: 0.75rem;
  }

  .form-field {
    margin-bottom: 0.5rem;
  }

  .form-field-lg {
    margin-bottom: 0.75rem;
  }

  /* ================================================================
     RESPONSIVE
  ================================================================ */

  @media (max-width: 480px) {
    .gate-form {
      flex-direction: column;
    }

    .slide {
      padding: 3rem 0;
    }

    .data-grid,
    .product-callouts,
    .tier-cards,
    .traction-cols,
    .unit-econ,
    .fin-callouts,
    .ask-grid,
    .big-numbers {
