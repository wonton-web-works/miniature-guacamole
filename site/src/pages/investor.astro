---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'node:fs';
import { parse } from 'yaml';
import { join } from 'node:path';

// Load the general fund profile at build time as default
const fundsDir = join(process.cwd(), 'src/data/funds');
const generalYaml = readFileSync(join(fundsDir, 'general.yaml'), 'utf-8');
const generalFund = parse(generalYaml);

// Build a map of all fund profiles for client-side selection
const fundFiles = import.meta.glob('../data/funds/*.yaml', { query: '?raw', import: 'default' });
const fundMap: Record<string, any> = {};
for (const [path, loader] of Object.entries(fundFiles)) {
  const slug = path.split('/').pop()?.replace('.yaml', '') ?? '';
  const raw = await loader() as string;
  fundMap[slug] = parse(raw);
}
---

