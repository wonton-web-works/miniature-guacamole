#!/usr/bin/env bash
# ============================================================================
# mg-memory-write - Atomic JSON updates with backup
# ============================================================================
# Usage: mg-memory-write <file.json> '<jq expression>'
# Exit 0 = success, Exit 1 = error
# ============================================================================

set -euo pipefail

# ============================================================================
# Help text
# ============================================================================
show_help() {
    cat <<EOF
Usage: mg-memory-write <file.json> '<jq expression>'

Atomically update JSON memory files with automatic .bak backup.

Arguments:
  <file.json>       Path to JSON file to update
  <jq expression>   jq expression to apply (must produce valid JSON object/array)

Options:
  -h, --help        Show this help message

Examples:
  mg-memory-write workstream.json '.status = "completed"'
  mg-memory-write tasks.json '.tests.passing = 15'
  mg-memory-write state.json '.status = "done" | .phase = "verified"'

Features:
  - Atomic updates (write to temp file, then move)
  - Automatic .bak backup of original file
  - Pretty-printed output (2-space indentation)
  - Validates result is valid JSON object or array

Dependencies:
  jq - JSON processor (required)

Exit codes:
  0 - Success
  1 - Error (file not found, invalid JSON, permission denied, etc.)
EOF
}

# ============================================================================
# Error handling
# ============================================================================
error() {
    echo "Error: $1" >&2
    exit 1
}

# ============================================================================
# Main
# ============================================================================

# Check for help flags
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    show_help
    exit 0
fi

# Validate argument count
if [[ $# -eq 0 ]]; then
    error "No arguments provided. Usage: mg-memory-write <file.json> '<jq expression>'"
fi

if [[ $# -eq 1 ]]; then
    error "Missing jq expression. Usage: mg-memory-write <file.json> '<jq expression>'"
fi

if [[ $# -gt 2 ]]; then
    error "Too many arguments. Usage: mg-memory-write <file.json> '<jq expression>'"
fi

FILE_PATH="$1"
JQ_EXPRESSION="$2"

# Locate jq using portable command detection
JQ_PATH=$(command -v jq)
if [[ -z "$JQ_PATH" ]]; then
    error "jq not found in PATH. Install via: brew install jq"
fi

# Check if file exists
if [[ ! -e "$FILE_PATH" ]]; then
    error "File not found: $FILE_PATH"
fi

# Resolve symlinks to get the real file path
if [[ -L "$FILE_PATH" ]]; then
    # Follow symlink to real file
    REAL_PATH=$(readlink -f "$FILE_PATH" 2>/dev/null || realpath "$FILE_PATH" 2>/dev/null || echo "")
    if [[ -z "$REAL_PATH" ]] || [[ ! -e "$REAL_PATH" ]]; then
        error "Symlink target does not exist: $FILE_PATH"
    fi
    FILE_PATH="$REAL_PATH"
fi

# Check if it's a directory
if [[ -d "$FILE_PATH" ]]; then
    error "Path is a directory, not a file: $FILE_PATH"
fi

# Check if file is readable
if [[ ! -r "$FILE_PATH" ]]; then
    error "File cannot be read (permission denied): $FILE_PATH"
fi

# Check if file is writable
if [[ ! -w "$FILE_PATH" ]]; then
    error "File cannot be written (permission denied): $FILE_PATH"
fi

# Get directory of the file
FILE_DIR="$(dirname "$FILE_PATH")"

# Check if directory is writable (needed for backup and temp file)
if [[ ! -w "$FILE_DIR" ]]; then
    error "Directory is not writable (cannot create backup): $FILE_DIR"
fi

# Create backup file
BACKUP_PATH="${FILE_PATH}.bak"
if ! cp "$FILE_PATH" "$BACKUP_PATH" 2>/dev/null; then
    error "Failed to create backup file: $BACKUP_PATH"
fi

# Create temp file for atomic write
TEMP_FILE=$(mktemp "${FILE_PATH}.tmp.XXXXXX")
ERROR_FILE=$(mktemp "${FILE_PATH}.err.XXXXXX")

# Apply jq transformation
if ! "$JQ_PATH" "$JQ_EXPRESSION" "$FILE_PATH" > "$TEMP_FILE" 2>"$ERROR_FILE"; then
    ERROR_MSG=$(cat "$ERROR_FILE" 2>/dev/null || echo "")
    rm -f "$TEMP_FILE" "$ERROR_FILE"

    # Determine if it's a parse error or expression error
    if [[ "$ERROR_MSG" =~ "parse error" ]]; then
        error "Invalid JSON in file: parse error"
    else
        error "Invalid jq expression or JSON processing error"
    fi
fi

rm -f "$ERROR_FILE"

# Validate that the result is not empty
if [[ ! -s "$TEMP_FILE" ]]; then
    rm -f "$TEMP_FILE"
    error "jq expression produced empty output (invalid result)"
fi

# Validate that result is valid JSON object or array (not a bare string/number)
RESULT_TYPE=$("$JQ_PATH" -r 'type' "$TEMP_FILE" 2>/dev/null || echo "error")
if [[ "$RESULT_TYPE" != "object" ]] && [[ "$RESULT_TYPE" != "array" ]]; then
    rm -f "$TEMP_FILE"
    error "jq expression must produce a JSON object or array, not a $RESULT_TYPE"
fi

# Pretty-print the result
if ! "$JQ_PATH" '.' "$TEMP_FILE" > "${TEMP_FILE}.pretty" 2>/dev/null; then
    rm -f "$TEMP_FILE" "${TEMP_FILE}.pretty"
    error "Failed to pretty-print result"
fi

# Atomic move (replace original file)
if ! mv "${TEMP_FILE}.pretty" "$FILE_PATH" 2>/dev/null; then
    rm -f "$TEMP_FILE" "${TEMP_FILE}.pretty"
    error "Failed to update file (atomic move failed)"
fi

# Clean up temp file if it still exists
rm -f "$TEMP_FILE"

# ============================================================================
# Postgres dual-write (optional — only when MG_POSTGRES_URL is set or config enables it)
# ============================================================================

# Resolve postgres URL: env var > config file > empty (no postgres)
# NOTE: MG_POSTGRES_URL env var bypasses storage_mode — unset it to respect config storage_mode=file
_resolve_pg_url() {
    if [[ -n "${MG_POSTGRES_URL:-}" ]]; then
        echo "$MG_POSTGRES_URL"
        return
    fi
    local config_dir="${MG_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/miniature-guacamole}"
    local config_file="$config_dir/config.json"
    if [[ -f "$config_file" ]]; then
        local storage_mode
        storage_mode=$(jq -r '.storage_mode // "file"' "$config_file" 2>/dev/null || echo "file")
        if [[ "$storage_mode" == "postgres" ]]; then
            jq -r '.postgres_url // ""' "$config_file" 2>/dev/null || echo ""
        fi
    fi
}

PG_URL=$(_resolve_pg_url || true)
if [[ -n "$PG_URL" ]]; then
    # Derive key from filename (basename without .json)
    FILE_BASENAME=$(basename "$FILE_PATH")
    FILE_KEY="${FILE_BASENAME%.json}"

    # Build SQL in temp files in $TMPDIR (Fix 5: avoid writing next to the target file)
    # Prefix includes table name so psql arg remains grep-able in tests
    PG_MEMORY_SQL=$(mktemp -t "memory_entries")
    PG_WS_SQL=$(mktemp -t "workstreams")

    # Always upsert to memory_entries (Fix 1: include all NOT NULL columns)
    cat > "$PG_MEMORY_SQL" <<EOSQL
INSERT INTO memory_entries (key, agent_id, workstream_id, timestamp, data, updated_at, version, file_path)
VALUES (
    :'file_key',
    'mg-memory-write',
    :'file_key',
    NOW(),
    \$pg_data\$
EOSQL

    # Append JSON content (never in bash variable to avoid injection)
    cat "$FILE_PATH" >> "$PG_MEMORY_SQL"

    cat >> "$PG_MEMORY_SQL" <<EOSQL
\$pg_data\$::jsonb,
    NOW(),
    1,
    :'file_path'
)
ON CONFLICT (key) DO UPDATE
    SET data       = EXCLUDED.data,
        file_path  = EXCLUDED.file_path,
        updated_at = NOW(),
        version    = memory_entries.version + 1;
EOSQL

    # Execute memory_entries upsert — failure is non-fatal
    PG_FAILED=false
    if ! psql "$PG_URL" \
            -v "file_key=$FILE_KEY" \
            -v "file_path=$FILE_PATH" \
            -f "$PG_MEMORY_SQL" >/dev/null 2>&1; then
        PG_FAILED=true
    fi
    rm -f "$PG_MEMORY_SQL"

    # If workstream state file, also upsert to workstreams table
    if [[ "$FILE_BASENAME" =~ ^workstream-.*-state\.json$ ]]; then
        WS_ID=$(jq -r '.workstream_id // ""' "$FILE_PATH" 2>/dev/null || echo "")
        WS_NAME=$(jq -r '.name // ""' "$FILE_PATH" 2>/dev/null || echo "")
        WS_PHASE=$(jq -r '.phase // "planning"' "$FILE_PATH" 2>/dev/null || echo "planning")
        WS_GATE=$(jq -r '.gate_status // ""' "$FILE_PATH" 2>/dev/null || echo "")
        WS_BLOCKER=$(jq -r '.blocker // ""' "$FILE_PATH" 2>/dev/null || echo "")
        WS_AGENT=$(jq -r '.agent_id // ""' "$FILE_PATH" 2>/dev/null || echo "")

        # SQL file for workstreams upsert (Fix 3: use -v named variables, not string interpolation)
        cat > "$PG_WS_SQL" <<EOSQL
INSERT INTO workstreams (workstream_id, name, phase, gate_status, blocker, agent_id, data, updated_at)
VALUES (
    :'ws_id',
    NULLIF(:'ws_name', ''),
    :'ws_phase',
    NULLIF(:'ws_gate', ''),
    NULLIF(:'ws_blocker', ''),
    NULLIF(:'ws_agent', ''),
    \$ws_data\$
EOSQL

        cat "$FILE_PATH" >> "$PG_WS_SQL"

        cat >> "$PG_WS_SQL" <<EOSQL
\$ws_data\$::jsonb,
    NOW()
)
ON CONFLICT (workstream_id) DO UPDATE
    SET name        = EXCLUDED.name,
        phase       = EXCLUDED.phase,
        gate_status = EXCLUDED.gate_status,
        blocker     = EXCLUDED.blocker,
        agent_id    = EXCLUDED.agent_id,
        data        = EXCLUDED.data,
        updated_at  = NOW();
EOSQL

        if ! psql "$PG_URL" \
                -v "ws_id=$WS_ID" \
                -v "ws_name=$WS_NAME" \
                -v "ws_phase=$WS_PHASE" \
                -v "ws_gate=$WS_GATE" \
                -v "ws_blocker=$WS_BLOCKER" \
                -v "ws_agent=$WS_AGENT" \
                -f "$PG_WS_SQL" >/dev/null 2>&1; then
            PG_FAILED=true
        fi
    fi
    rm -f "$PG_WS_SQL"

    if [[ "$PG_FAILED" == true ]]; then
        echo "WARN: Postgres dual-write failed for $FILE_PATH — file write succeeded" >&2
    fi
fi

exit 0
