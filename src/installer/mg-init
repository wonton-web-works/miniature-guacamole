#!/usr/bin/env bash

# mg-init - Initialize a project with miniature-guacamole
#
# Usage: mg-init [OPTIONS] [PROJECT_DIR]
#
# Options:
#   --version VERSION  Specific version to install (default: latest)
#   --force            Force re-initialization (overwrites existing templates)
#   --offline          Cache only, no network (fail if not cached)
#   --help             Show this help message
#
# Arguments:
#   PROJECT_DIR        Target project directory (default: current directory)
#
# Description:
#   Initializes a project with miniature-guacamole by:
#   1. Checking local cache (~/.cache/miniature-guacamole/)
#   2. If cache miss, fetching from GitHub releases API
#   3. Downloading and caching tarball
#   4. Extracting to temp directory
#   5. Running bundled install.sh
#
#   Safe to run multiple times (idempotent).

set -euo pipefail

# Security hardening - prevent sourcing
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    echo "Error: This script must be executed, not sourced" >&2
    return 1
fi

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
CACHE_DIR="$HOME/.cache/miniature-guacamole"
GITHUB_REPO="wonton-web-works/miniature-guacamole"
GITHUB_API="https://api.github.com/repos/$GITHUB_REPO"
VERSION="latest"
FORCE=false
OFFLINE=false
NO_DB=false
PROJECT_DIR="$PWD"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --version)
            VERSION="$2"
            shift 2
            ;;
        --force)
            FORCE=true
            shift
            ;;
        --offline)
            OFFLINE=true
            shift
            ;;
        --no-db)
            NO_DB=true
            shift
            ;;
        --help)
            # Extract and display help from header comments
            sed -n '/^# mg-init/,/^$/p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        -*)
            echo -e "${RED}Error: Unknown option: $1${NC}" >&2
            echo "Run 'mg-init --help' for usage information." >&2
            exit 1
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

# Resolve absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
    echo -e "${RED}Error: Project directory does not exist: $PROJECT_DIR${NC}" >&2
    exit 1
}

echo -e "${BLUE}Initializing miniature-guacamole in: $PROJECT_DIR${NC}"
echo ""

# Create cache directory
mkdir -p "$CACHE_DIR"

# Resolve GitHub auth token (needed for private repos)
AUTH_HEADER=""
if command -v gh &>/dev/null; then
    GH_TOKEN=$(gh auth token 2>/dev/null) && AUTH_HEADER="Authorization: token $GH_TOKEN"
elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
    AUTH_HEADER="Authorization: token $GITHUB_TOKEN"
fi

# Function to resolve latest version
resolve_latest_version() {
    if [[ "$OFFLINE" == "true" ]]; then
        echo -e "${RED}Error: Cannot resolve 'latest' version in offline mode${NC}" >&2
        echo "Please specify a version with --version" >&2
        exit 1
    fi

    echo -e "${BLUE}Fetching latest version from GitHub...${NC}" >&2

    local response
    response=$(curl -s ${AUTH_HEADER:+-H "$AUTH_HEADER"} "$GITHUB_API/releases/latest") || {
        echo -e "${RED}Error: Failed to fetch latest release from GitHub${NC}" >&2
        exit 1
    }

    local latest
    latest=$(echo "$response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('tag_name', ''))" 2>/dev/null) || {
        echo -e "${RED}Error: Failed to parse GitHub API response${NC}" >&2
        exit 1
    }

    if [[ -z "$latest" ]]; then
        echo -e "${RED}Error: No releases found in repository${NC}" >&2
        exit 1
    fi

    echo "$latest"
}

# Function to get tarball URL for version
get_tarball_url() {
    local version="$1"

    if [[ "$OFFLINE" == "true" ]]; then
        return 0
    fi

    echo -e "${BLUE}Fetching release information for $version...${NC}" >&2

    local response
    response=$(curl -s ${AUTH_HEADER:+-H "$AUTH_HEADER"} "$GITHUB_API/releases/tags/$version") || {
        echo -e "${RED}Error: Failed to fetch release $version from GitHub${NC}" >&2
        exit 1
    }

    local tarball_url
    # Prefer release asset API URL (works for private repos), fall back to source tarball
    tarball_url=$(echo "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for a in d.get('assets', []):
    if a['name'] == 'miniature-guacamole.tar.gz':
        print(a['url'])
        sys.exit(0)
# Fallback to source tarball
url = d.get('tarball_url', '')
if url:
    print(url)
else:
    sys.exit(1)
" 2>/dev/null) || {
        echo -e "${RED}Error: Failed to parse GitHub API response${NC}" >&2
        exit 1
    }

    if [[ -z "$tarball_url" ]]; then
        echo -e "${RED}Error: Release $version not found${NC}" >&2
        exit 1
    fi

    echo "$tarball_url"
}

# Function to download and cache tarball
download_and_cache() {
    local version="$1"
    local tarball_url="$2"
    local cache_file="$CACHE_DIR/$version.tar.gz"

    echo -e "${BLUE}Downloading $version from GitHub...${NC}" >&2

    # Download with progress bar (Accept header needed for GitHub asset API)
    curl -L ${AUTH_HEADER:+-H "$AUTH_HEADER"} -H "Accept: application/octet-stream" -o "$cache_file.tmp" --progress-bar "$tarball_url" || {
        echo -e "${RED}Error: Failed to download tarball${NC}" >&2
        rm -f "$cache_file.tmp"
        exit 1
    }

    # Atomic move
    mv "$cache_file.tmp" "$cache_file"

    echo -e "${GREEN}Cached $version to $cache_file${NC}" >&2
    echo "$cache_file"
}

# Function to extract tarball to temp directory
extract_tarball() {
    local cache_file="$1"
    local temp_dir
    temp_dir=$(mktemp -d -t mg-init.XXXXXX) || {
        echo -e "${RED}Error: Failed to create temporary directory${NC}" >&2
        exit 1
    }

    echo -e "${BLUE}Extracting tarball to $temp_dir...${NC}" >&2

    tar -xzf "$cache_file" -C "$temp_dir" --strip-components=1 || {
        echo -e "${RED}Error: Failed to extract tarball${NC}" >&2
        rm -rf "$temp_dir"
        exit 1
    }

    echo "$temp_dir"
}

# Function to find mg-postgres binary (PATH lookup, then sibling script)
find_mg_postgres() {
    if command -v mg-postgres &>/dev/null; then echo "mg-postgres"; return; fi
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [[ -x "$script_dir/mg-postgres" ]]; then echo "$script_dir/mg-postgres"; return; fi
    echo ""
}

# Function to find mg-migrate binary (PATH lookup, then sibling script)
find_mg_migrate() {
    if command -v mg-migrate &>/dev/null; then echo "mg-migrate"; return; fi
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [[ -x "$script_dir/mg-migrate" ]]; then echo "$script_dir/mg-migrate"; return; fi
    echo ""
}

# Main workflow

# Resolve version if "latest"
if [[ "$VERSION" == "latest" ]]; then
    VERSION=$(resolve_latest_version)
    echo -e "${GREEN}Latest version: $VERSION${NC}"
    echo ""
fi

# Check cache
CACHE_FILE="$CACHE_DIR/$VERSION.tar.gz"

if [[ -f "$CACHE_FILE" ]]; then
    echo -e "${GREEN}Found cached version: $VERSION${NC}"
    echo -e "${BLUE}Cache file: $CACHE_FILE${NC}"
    echo ""
else
    if [[ "$OFFLINE" == "true" ]]; then
        echo -e "${RED}Error: Version $VERSION not found in cache${NC}" >&2
        echo "Cache directory: $CACHE_DIR" >&2
        echo "Cached versions:" >&2
        ls -1 "$CACHE_DIR" 2>/dev/null | grep '\.tar\.gz$' | sed 's/\.tar\.gz$//' | sed 's/^/  /' >&2 || echo "  (none)" >&2
        exit 1
    fi

    # Fetch tarball URL
    TARBALL_URL=$(get_tarball_url "$VERSION")

    # Download and cache
    CACHE_FILE=$(download_and_cache "$VERSION" "$TARBALL_URL")
    echo ""
fi

# Extract tarball
TEMP_DIR=$(extract_tarball "$CACHE_FILE")
echo ""

# Verify install.sh exists (check multiple locations)
INSTALL_SCRIPT=""
for candidate in \
    "$TEMP_DIR/dist/miniature-guacamole/install.sh" \
    "$TEMP_DIR/install.sh"; do
    if [[ -f "$candidate" ]]; then
        INSTALL_SCRIPT="$candidate"
        break
    fi
done

if [[ -z "$INSTALL_SCRIPT" ]]; then
    echo -e "${RED}Error: install.sh not found in tarball${NC}" >&2
    echo "Contents of tarball:" >&2
    find "$TEMP_DIR" -type f | head -20 >&2
    rm -rf "$TEMP_DIR"
    exit 1
fi

# Make install.sh executable
chmod +x "$INSTALL_SCRIPT"

# Run install.sh with appropriate flags
echo -e "${BLUE}Running install.sh...${NC}"
echo ""

INSTALL_FLAGS=()

if [[ "$FORCE" == "true" ]]; then
    INSTALL_FLAGS+=("--force")
fi

# Run install.sh against project directory
"$INSTALL_SCRIPT" "${INSTALL_FLAGS[@]}" "$PROJECT_DIR" || {
    echo -e "${RED}Error: install.sh failed${NC}" >&2
    rm -rf "$TEMP_DIR"
    exit 1
}

# Cleanup temp directory
rm -rf "$TEMP_DIR"

# DB provisioning + migration (skipped with --no-db)
DB_STATUS="file mode (no database)"
MIGRATION_SUMMARY=""

if [[ "$NO_DB" == "false" ]]; then
    if ! command -v docker &>/dev/null; then
        echo -e "${YELLOW}WARN: Docker not available — skipping Postgres provisioning (file mode)${NC}"
        DB_STATUS="file mode (Docker unavailable)"
    else
        MG_POSTGRES_BIN="$(find_mg_postgres)"
        if [[ -n "$MG_POSTGRES_BIN" ]]; then
            echo -e "${BLUE}Starting Postgres...${NC}"
            if "$MG_POSTGRES_BIN" start 2>&1; then
                DB_STATUS="Postgres (ready)"
                # Run migration
                MG_MIGRATE_BIN="$(find_mg_migrate)"
                if [[ -n "$MG_MIGRATE_BIN" ]]; then
                    echo -e "${BLUE}Migrating existing memory files...${NC}"
                    if MIGRATION_SUMMARY=$("$MG_MIGRATE_BIN" "$PROJECT_DIR" 2>&1); then
                        echo -e "${GREEN}Migration: $MIGRATION_SUMMARY${NC}"
                    else
                        echo -e "${YELLOW}WARN: Migration failed — continuing in file mode${NC}"
                        MIGRATION_SUMMARY=""
                        DB_STATUS="Postgres (ready, migration failed)"
                    fi
                fi
            else
                echo -e "${YELLOW}WARN: Postgres provisioning failed — falling back to file mode${NC}"
                DB_STATUS="file mode (provisioning failed)"
            fi
        else
            echo -e "${YELLOW}WARN: mg-postgres not found — skipping DB provisioning${NC}"
            DB_STATUS="file mode (mg-postgres not found)"
        fi
    fi
else
    DB_STATUS="file mode (--no-db)"
fi

echo ""
echo -e "${GREEN}miniature-guacamole $VERSION initialized${NC}"
echo ""
echo "  Project: $PROJECT_DIR"
echo "  DB:      $DB_STATUS"
if [[ -n "$MIGRATION_SUMMARY" ]]; then
    echo "  Migrated: $MIGRATION_SUMMARY"
fi
echo ""
echo "Next steps:"
echo "  /mg-init    — re-run any time to upgrade"
echo "  /mg-build   — start a workstream"
echo ""
