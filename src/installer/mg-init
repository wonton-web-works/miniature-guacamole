#!/usr/bin/env bash

# mg-init - Initialize a project with miniature-guacamole
#
# Usage: mg-init [OPTIONS] [PROJECT_DIR]
#
# Options:
#   --force            Force re-initialization (overwrites existing templates)
#   --no-db            Skip database provisioning
#   --help             Show this help message
#
# Arguments:
#   PROJECT_DIR        Target project directory (default: current directory)
#
# Description:
#   Initializes a project with miniature-guacamole using the globally
#   installed bundle at ~/.miniature-guacamole/. No network required.
#
#   Safe to run multiple times (idempotent).

set -euo pipefail

# Security hardening - prevent sourcing
# When piped (curl | bash), BASH_SOURCE[0] is unset — skip the guard in that case
if [[ -n "${BASH_SOURCE[0]:-}" ]] && [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    echo "Error: This script must be executed, not sourced" >&2
    return 1
fi

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
MG_HOME="$HOME/.miniature-guacamole"
FORCE=false
NO_DB=false
PROJECT_DIR="$PWD"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force)
            FORCE=true
            shift
            ;;
        --no-db)
            NO_DB=true
            shift
            ;;
        --help)
            # Extract and display help from header comments
            sed -n '/^# mg-init/,/^$/p' "${BASH_SOURCE[0]:-$0}" | sed 's/^# \?//'
            exit 0
            ;;
        -*)
            echo -e "${RED}Error: Unknown option: $1${NC}" >&2
            echo "Run 'mg-init --help' for usage information." >&2
            exit 1
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

# Resolve absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
    echo -e "${RED}Error: Project directory does not exist: $PROJECT_DIR${NC}" >&2
    exit 1
}

echo -e "${BLUE}Initializing miniature-guacamole in: $PROJECT_DIR${NC}"
echo ""

# Verify global bundle exists
INSTALL_SCRIPT="$MG_HOME/install.sh"
if [[ ! -f "$INSTALL_SCRIPT" ]]; then
    echo -e "${RED}Error: miniature-guacamole is not installed globally${NC}" >&2
    echo "" >&2
    echo "Run the global installer first:" >&2
    echo "  curl -fsSL https://raw.githubusercontent.com/wonton-web-works/miniature-guacamole/main/src/installer/web-install.sh | bash" >&2
    exit 1
fi

# Read version from global bundle
VERSION="unknown"
if [[ -f "$MG_HOME/VERSION.json" ]]; then
    VERSION=$(python3 -c "import json; print(json.load(open('$MG_HOME/VERSION.json')).get('version', 'unknown'))" 2>/dev/null || echo "unknown")
fi

echo -e "${GREEN}Using global bundle: $MG_HOME (v$VERSION)${NC}"
echo ""

# Build install flags
INSTALL_FLAGS=()
if [[ "$FORCE" == "true" ]]; then
    INSTALL_FLAGS+=("--force")
fi

# Run install.sh from global bundle
echo -e "${BLUE}Running install.sh...${NC}"
echo ""

"$INSTALL_SCRIPT" "${INSTALL_FLAGS[@]}" "$PROJECT_DIR" || {
    echo -e "${RED}Error: install.sh failed${NC}" >&2
    exit 1
}

# Function to find mg-postgres binary (PATH lookup, then global bundle scripts)
find_mg_postgres() {
    if command -v mg-postgres &>/dev/null; then echo "mg-postgres"; return; fi
    if [[ -x "$MG_HOME/.claude/scripts/mg-postgres" ]]; then echo "$MG_HOME/.claude/scripts/mg-postgres"; return; fi
    echo ""
}

# Function to find mg-migrate binary (PATH lookup, then global bundle)
find_mg_migrate() {
    if command -v mg-migrate &>/dev/null; then echo "mg-migrate"; return; fi
    if [[ -x "$MG_HOME/mg-migrate" ]]; then echo "$MG_HOME/mg-migrate"; return; fi
    echo ""
}

# DB provisioning + migration (skipped with --no-db)
DB_STATUS="file mode (no database)"
MIGRATION_SUMMARY=""

if [[ "$NO_DB" == "false" ]]; then
    if ! command -v docker &>/dev/null; then
        echo -e "${YELLOW}WARN: Docker not available — skipping Postgres provisioning (file mode)${NC}"
        DB_STATUS="file mode (Docker unavailable)"
    else
        MG_POSTGRES_BIN="$(find_mg_postgres)"
        if [[ -n "$MG_POSTGRES_BIN" ]]; then
            echo -e "${BLUE}Starting Postgres...${NC}"
            if "$MG_POSTGRES_BIN" start 2>&1; then
                DB_STATUS="Postgres (ready)"
                # Run migration
                MG_MIGRATE_BIN="$(find_mg_migrate)"
                if [[ -n "$MG_MIGRATE_BIN" ]]; then
                    echo -e "${BLUE}Migrating existing memory files...${NC}"
                    if MIGRATION_SUMMARY=$("$MG_MIGRATE_BIN" "$PROJECT_DIR" 2>&1); then
                        echo -e "${GREEN}Migration: $MIGRATION_SUMMARY${NC}"
                    else
                        echo -e "${YELLOW}WARN: Migration failed — continuing in file mode${NC}"
                        MIGRATION_SUMMARY=""
                        DB_STATUS="Postgres (ready, migration failed)"
                    fi
                fi
            else
                echo -e "${YELLOW}WARN: Postgres provisioning failed — falling back to file mode${NC}"
                DB_STATUS="file mode (provisioning failed)"
            fi
        else
            echo -e "${YELLOW}WARN: mg-postgres not found — skipping DB provisioning${NC}"
            DB_STATUS="file mode (mg-postgres not found)"
        fi
    fi
else
    DB_STATUS="file mode (--no-db)"
fi

echo ""
echo -e "${GREEN}miniature-guacamole $VERSION initialized${NC}"
echo ""
echo "  Project: $PROJECT_DIR"
echo "  DB:      $DB_STATUS"
if [[ -n "$MIGRATION_SUMMARY" ]]; then
    echo "  Migrated: $MIGRATION_SUMMARY"
fi
echo ""
echo "Next steps:"
echo "  mg-init    — re-run any time to upgrade"
echo "  /mg-build  — start a workstream"
echo ""
