@test "mg-util init: multiple successive initializations (idempotent)" {
    # AC-6: Should be safe to run multiple times on same project
    local project_dir="$TEST_DIR/multi-init-project"
    mkdir -p "$project_dir"

    # First initialization
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Second initialization
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Third initialization
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
}

@test "mg-util init: absolute path project directory" {
    # AC-1: Should handle absolute paths
    local project_dir="$TEST_DIR/absolute-path-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: relative path project directory" {
    # AC-1: Should handle relative paths
    local project_dir="relative-project"
    mkdir -p "$TEST_DIR/$project_dir"

    cd "$TEST_DIR" || exit 1
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$TEST_DIR/$project_dir/.claude/memory" ]]
}

@test "mg-util init: template file permissions preserved" {
    # Should preserve executable permissions on template files if any
    local project_dir="$TEST_DIR/permissions-project"
    mkdir -p "$project_dir"

    # Create executable template
    mkdir -p "$MG_INSTALL_ROOT/templates/scripts"
    echo "#!/bin/bash" > "$MG_INSTALL_ROOT/templates/scripts/init-hook.sh"
    chmod +x "$MG_INSTALL_ROOT/templates/scripts/init-hook.sh"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify executable bit preserved
    if [[ -f "$project_dir/.claude/scripts/init-hook.sh" ]]; then
        [[ -x "$project_dir/.claude/scripts/init-hook.sh" ]]
    fi
}

