#!/usr/bin/env bats
# ============================================================================
# mg-util-init.bats - Tests for mg-util init command
# ============================================================================
# Test ordering: MISUSE CASES → BOUNDARY TESTS → GOLDEN PATH
# Coverage target: 99% of mg-util init functionality
#
# Acceptance Criteria:
# AC-1: mg-util init [project-dir] creates .claude/memory/ structure and CLAUDE.md
# AC-2: mg-util init uses ~/.miniature-guacamole/ installation root for templates
# AC-6: Init handles existing project gracefully (idempotent)
# ============================================================================

# Setup and teardown
setup() {
    # Test fixtures directory
    FIXTURES_DIR="$(cd "$(dirname "$BATS_TEST_FILENAME")/fixtures" && pwd)"

    # Temporary test directory
    TEST_DIR="$(mktemp -d)"

    # Resolve project root (tests/scripts/ → project root)
    PROJECT_ROOT="$(cd "$(dirname "$BATS_TEST_FILENAME")/../.." && pwd)"

    # Mock installation root for testing
    MG_INSTALL_ROOT="$TEST_DIR/.miniature-guacamole"
    mkdir -p "$MG_INSTALL_ROOT"

    # Create test script directory
    TEST_SCRIPTS_DIR="$TEST_DIR/scripts"
    mkdir -p "$TEST_SCRIPTS_DIR"

    # Copy mg-util script (when implemented) or use placeholder
    if [[ -f "$PROJECT_ROOT/src/framework/scripts/mg-util" ]]; then
        cp "$PROJECT_ROOT/src/framework/scripts/mg-util" "$TEST_SCRIPTS_DIR/"
        chmod +x "$TEST_SCRIPTS_DIR/mg-util"
    else
        # Placeholder for TDD - tests define the contract
        touch "$TEST_SCRIPTS_DIR/mg-util"
        chmod +x "$TEST_SCRIPTS_DIR/mg-util"
    fi

    SCRIPT_PATH="$TEST_SCRIPTS_DIR/mg-util"

    # Create mock template files in installation root
    mkdir -p "$MG_INSTALL_ROOT/templates/memory"
    mkdir -p "$MG_INSTALL_ROOT/templates/project"

    # Mock CLAUDE.md template
    cat > "$MG_INSTALL_ROOT/templates/project/CLAUDE.md" <<'EOF'
# Project Context

Generated by miniature-guacamole init
EOF

    # Mock memory file templates
    echo '{}' > "$MG_INSTALL_ROOT/templates/memory/tasks-dev.json"
    echo '{}' > "$MG_INSTALL_ROOT/templates/memory/decisions.json"

    # Skip if BATS not installed
    if ! command -v bats &> /dev/null; then
        skip "BATS not installed. Install via: brew install bats-core"
    fi
}

teardown() {
    # Clean up temporary directory
    if [[ -n "$TEST_DIR" && -d "$TEST_DIR" ]]; then
        rm -rf "$TEST_DIR"
    fi
}

# ============================================================================
# MISUSE CASES - Invalid inputs, missing dependencies, error conditions
# ============================================================================

@test "mg-util init: missing installation root directory" {
    # AC-2: Should fail if ~/.miniature-guacamole/ doesn't exist
    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    # Remove mock installation root to simulate missing install
    rm -rf "$MG_INSTALL_ROOT"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "installation" ]] || [[ "$output" =~ "not found" ]]
}

@test "mg-util init: missing template files" {
    # AC-2: Should fail if required templates are missing
    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    # Remove templates to simulate incomplete installation
    rm -rf "$MG_INSTALL_ROOT/templates"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "template" ]] || [[ "$output" =~ "missing" ]]
}

@test "mg-util init: invalid project directory path" {
    # AC-1: Should reject paths with invalid characters
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "/invalid\x00path"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "invalid" ]] || [[ "$output" =~ "path" ]]
}

@test "mg-util init: project directory is a file" {
    # AC-1: Should fail if target path exists as a file
    local file_path="$TEST_DIR/not-a-directory"
    touch "$file_path"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$file_path"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "not a directory" ]] || [[ "$output" =~ "file exists" ]]
}

@test "mg-util init: unwritable project directory" {
    # AC-1: Should fail if project directory isn't writable
    local project_dir="$TEST_DIR/readonly-project"
    mkdir -p "$project_dir"
    chmod 500 "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    status_code="$status"

    # Restore permissions for cleanup
    chmod 700 "$project_dir"

    [ "$status_code" -eq 1 ]
    [[ "$output" =~ "permission" ]] || [[ "$output" =~ "write" ]]
}

@test "mg-util init: unreadable installation root" {
    # AC-2: Should fail if cannot read from installation root
    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    chmod 000 "$MG_INSTALL_ROOT"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    status_code="$status"

    # Restore permissions for cleanup
    chmod 700 "$MG_INSTALL_ROOT"

    [ "$status_code" -eq 1 ]
    [[ "$output" =~ "permission" ]] || [[ "$output" =~ "read" ]]
}

@test "mg-util init: missing required command dependencies" {
    # Should fail gracefully if required commands (mkdir, cp) unavailable
    skip "TODO: Mock PATH to test dependency detection"
}

@test "mg-util init: disk full during directory creation" {
    # Should fail gracefully if disk is full
    skip "TODO: Mock disk full condition"
}

@test "mg-util init: SIGINT during initialization (Ctrl+C)" {
    # Should clean up partial state on interrupt
    skip "TODO: Test signal handling and cleanup"
}

@test "mg-util init: corrupted template file (invalid JSON)" {
    # AC-2: Should detect and report corrupted templates
    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    # Corrupt a template file
    echo '{invalid json' > "$MG_INSTALL_ROOT/templates/memory/tasks-dev.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 1 ]
    [[ "$output" =~ "corrupt" ]] || [[ "$output" =~ "invalid" ]]
}

@test "mg-util init: project path with trailing slash" {
    # AC-1: Should normalize paths correctly
    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir/"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: relative path outside current directory" {
    # AC-1: Should handle relative paths like ../../other-project
    local project_dir="$TEST_DIR/nested/deep/project"
    mkdir -p "$project_dir"

    cd "$TEST_DIR" || exit 1
    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "nested/deep/project"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

# ============================================================================
# BOUNDARY TESTS - Edge cases, limits, unusual but valid inputs
# ============================================================================

@test "mg-util init: project directory doesn't exist (auto-create)" {
    # AC-1: Should create project directory if it doesn't exist
    local project_dir="$TEST_DIR/new-project"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir" ]]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: empty project directory" {
    # AC-1: Should initialize empty directory successfully
    local project_dir="$TEST_DIR/empty-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
    [[ -f "$project_dir/.claude/CLAUDE.md" ]]
}

@test "mg-util init: project with existing .claude directory (no memory)" {
    # AC-6: Should be idempotent - add missing memory structure
    local project_dir="$TEST_DIR/partial-project"
    mkdir -p "$project_dir/.claude"
    echo "existing config" > "$project_dir/.claude/settings.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
    [[ -f "$project_dir/.claude/settings.json" ]]  # Existing file preserved
    grep -q "existing config" "$project_dir/.claude/settings.json"
}

@test "mg-util init: project with existing .claude/memory (idempotent)" {
    # AC-6: Should detect existing initialization and handle gracefully
    local project_dir="$TEST_DIR/initialized-project"
    mkdir -p "$project_dir/.claude/memory"
    echo '{"existing": "data"}' > "$project_dir/.claude/memory/tasks-dev.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "already initialized" ]] || [[ "$output" =~ "exists" ]]

    # Should NOT overwrite existing files
    grep -q "existing" "$project_dir/.claude/memory/tasks-dev.json"
}

@test "mg-util init: project with existing CLAUDE.md (preserve)" {
    # AC-6: Should preserve existing CLAUDE.md
    local project_dir="$TEST_DIR/existing-claude-md"
    mkdir -p "$project_dir/.claude"
    echo "# Custom Project Context" > "$project_dir/.claude/CLAUDE.md"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Should preserve custom content
    grep -q "Custom Project Context" "$project_dir/.claude/CLAUDE.md"
}

@test "mg-util init: no project directory argument (use current directory)" {
    # AC-1: Should default to current directory if no argument
    local project_dir="$TEST_DIR/current-dir-project"
    mkdir -p "$project_dir"
    cd "$project_dir" || exit 1

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init
    [ "$status" -eq 0 ]
    [[ -d "./.claude/memory" ]]
    [[ -f "./.claude/CLAUDE.md" ]]
}

@test "mg-util init: project path with spaces" {
    # AC-1: Should handle paths with spaces correctly
    local project_dir="$TEST_DIR/project with spaces"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: project path with special characters" {
    # AC-1: Should handle valid special characters (hyphens, underscores)
    local project_dir="$TEST_DIR/project-name_v2.0"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: deeply nested project path" {
    # AC-1: Should handle very deep directory structures
    local project_dir="$TEST_DIR/a/b/c/d/e/f/g/h/project"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: symlinked project directory" {
    # AC-1: Should handle symlinks to project directories
    local real_project="$TEST_DIR/real-project"
    local symlink_project="$TEST_DIR/symlink-project"
    mkdir -p "$real_project"
    ln -s "$real_project" "$symlink_project"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$symlink_project"
    [ "$status" -eq 0 ]
    [[ -d "$real_project/.claude/memory" ]] || [[ -d "$symlink_project/.claude/memory" ]]
}

@test "mg-util init: installation root is symlink" {
    # AC-2: Should resolve symlinked installation root
    local real_install="$TEST_DIR/real-mg-install"
    local symlink_install="$TEST_DIR/symlink-mg-install"

    mv "$MG_INSTALL_ROOT" "$real_install"
    ln -s "$real_install" "$symlink_install"

    local project_dir="$TEST_DIR/test-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$symlink_install" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: minimal template structure" {
    # AC-2: Should work with minimal required templates
    local project_dir="$TEST_DIR/minimal-project"
    mkdir -p "$project_dir"

    # Remove optional templates, keep only required ones
    rm -f "$MG_INSTALL_ROOT/templates/memory/tasks-dev.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: empty template files (zero-byte)" {
    # AC-2: Should handle empty template files gracefully
    local project_dir="$TEST_DIR/empty-template-project"
    mkdir -p "$project_dir"

    # Create empty template
    > "$MG_INSTALL_ROOT/templates/memory/empty.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
}

# ============================================================================
# GOLDEN PATH - Normal, expected operations
# ============================================================================

@test "mg-util init: create memory structure with all directories" {
    # AC-1: Should create complete .claude/memory/ structure
    local project_dir="$TEST_DIR/golden-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify memory directory exists
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: create CLAUDE.md from template" {
    # AC-1: Should create CLAUDE.md from template
    local project_dir="$TEST_DIR/claude-md-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify CLAUDE.md exists and contains template content
    [[ -f "$project_dir/.claude/CLAUDE.md" ]]
    grep -q "miniature-guacamole" "$project_dir/.claude/CLAUDE.md"
}

@test "mg-util init: copy memory template files" {
    # AC-2: Should copy all template files from installation root
    local project_dir="$TEST_DIR/template-copy-project"
    mkdir -p "$project_dir"

    # Create multiple template files
    echo '{"tasks": []}' > "$MG_INSTALL_ROOT/templates/memory/tasks-qa.json"
    echo '{"decisions": []}' > "$MG_INSTALL_ROOT/templates/memory/decisions.json"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify templates were copied
    [[ -f "$project_dir/.claude/memory/tasks-dev.json" ]]
    [[ -f "$project_dir/.claude/memory/tasks-qa.json" ]]
    [[ -f "$project_dir/.claude/memory/decisions.json" ]]
}

@test "mg-util init: use explicit project directory argument" {
    # AC-1: Should accept explicit project directory path
    local project_dir="$TEST_DIR/explicit-path-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ -d "$project_dir/.claude/memory" ]]
}

@test "mg-util init: verify installation root usage" {
    # AC-2: Should read templates from ~/.miniature-guacamole/
    local project_dir="$TEST_DIR/install-root-project"
    mkdir -p "$project_dir"

    # Add unique marker to template
    echo "UNIQUE_MARKER_12345" >> "$MG_INSTALL_ROOT/templates/project/CLAUDE.md"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify marker appears in created file (proves template source)
    grep -q "UNIQUE_MARKER_12345" "$project_dir/.claude/CLAUDE.md"
}

@test "mg-util init: success message output" {
    # Should output clear success message
    local project_dir="$TEST_DIR/success-msg-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
    [[ "$output" =~ "success" ]] || [[ "$output" =~ "initialized" ]] || [[ "$output" =~ "complete" ]]
}

@test "mg-util init: exit code 0 on success" {
    # Should return exit code 0 on successful initialization
    local project_dir="$TEST_DIR/exit-code-project"
    mkdir -p "$project_dir"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]
}

@test "mg-util init: preserve existing project files" {
    # AC-6: Should not delete or modify existing project files
    local project_dir="$TEST_DIR/preserve-files-project"
    mkdir -p "$project_dir/src"
    echo "existing code" > "$project_dir/src/main.ts"
    echo "existing docs" > "$project_dir/README.md"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    # Verify existing files unchanged
    [[ -f "$project_dir/src/main.ts" ]]
    [[ -f "$project_dir/README.md" ]]
    grep -q "existing code" "$project_dir/src/main.ts"
    grep -q "existing docs" "$project_dir/README.md"
}

@test "mg-util init: help flag displays usage" {
    # Should display help message with --help
    run "$SCRIPT_PATH" init --help
    [ "$status" -eq 0 ]
    [[ "$output" =~ "Usage:" ]] || [[ "$output" =~ "usage:" ]]
}

@test "mg-util init: help flag short form (-h)" {
    # Should display help message with -h
    run "$SCRIPT_PATH" init -h
    [ "$status" -eq 0 ]
    [[ "$output" =~ "Usage:" ]] || [[ "$output" =~ "usage:" ]]
}

@test "mg-util init: create memory subdirectories structure" {
    # AC-1: Should create expected subdirectory structure in memory/
    local project_dir="$TEST_DIR/memory-structure-project"
    mkdir -p "$project_dir"

    # Add subdirectory template
    mkdir -p "$MG_INSTALL_ROOT/templates/memory/workstreams"
    echo '{}' > "$MG_INSTALL_ROOT/templates/memory/workstreams/.gitkeep"

    run env MG_INSTALL_ROOT="$MG_INSTALL_ROOT" "$SCRIPT_PATH" init "$project_dir"
    [ "$status" -eq 0 ]

    [[ -d "$project_dir/.claude/memory/workstreams" ]]
}

